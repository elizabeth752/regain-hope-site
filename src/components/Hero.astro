---
import Icon from './Icon.astro';
// Sitewide hero. One consistent background (regain-03, set in global.css .hero).
//   variant="form"    → money pages (programs / substances): insurance verify form on the right
//   variant="reviews" → everything else: rotating 5-star review spotlight on the right
export interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  byline?: string;        // e.g. medically-reviewed line (programs/substance pages)
  bylineHref?: string;
  chips?: string[];       // small trust chips under the lead
  variant?: 'form' | 'reviews';
  cta?: { label: string; href: string }; // shown on reviews variant (form variant has its own button)
}
const {
  eyebrow, title, lead, byline, bylineHref = '/about-us/team/',
  chips = [], variant = 'reviews',
  cta = { label: 'Verify Your Insurance', href: '/admissions/verify-insurance/' },
} = Astro.props;

const reviews = [
  { text: 'The two doctors are genuinely caring and compassionate. In past detoxes I often felt treated like a number. Here they truly make you feel valued and cared for as a person.', who: 'Chris' },
  { text: 'Dr. Gomez and Dr. Carlos are incredible. They make the house feel like home and family, and Dr. Gomez genuinely cares, following up with clients even after discharge.', who: 'Jimmy' },
  { text: "They didn't make the facility feel cold or clinical. They made it feel like home. You could tell they genuinely cared about the people there.", who: 'Ashlie L.' },
];
const GBP = 'https://maps.app.goo.gl/S3YvacbqJG8mVm457';
---
<section class={`hero hero--${variant}`}>
  <div class="container">
    <div class="hero-inner">
      {eyebrow && <span class="eyebrow" style="color:#fff">{eyebrow}</span>}
      <h1>{title}</h1>
      {lead && <p class="lead">{lead}</p>}
      {byline && <p class="byline">Medically reviewed by <a href={bylineHref}>{byline}</a></p>}
      {chips.length > 0 && (
        <ul class="hero-points">
          {chips.map((c) => <li><span class="hp-ic"><Icon name="check" size={15} /></span>{c}</li>)}
        </ul>
      )}
      <p class="hero-talk" style="margin-top:22px;">Prefer to talk? <a href="tel:+18182812458" class="hero-phone-link">Call 24/7: (818) 281-2458</a></p>
      {variant === 'form' && (
        <div class="hero-cta-mobile">
          <a href={cta.href} class="btn btn-gold">Check my coverage →</a>
          <a href="tel:+18182812458" class="btn btn-ghost"><Icon name="phone" size={16} /> Call 24/7</a>
        </div>
      )}
    </div>

    {variant === 'form' ? (
      <div class="hero-form-wrap">
        <form class="hero-form" action="/thank-you/" method="get">
          <img class="form-hipaa" src="/images/logos/hipaa.svg" alt="HIPAA compliant" width="64" height="36" loading="lazy" />
          <h3>Verify Your Insurance</h3>
          <p class="fsub">Free and confidential. Leave your name and number and we'll call you right back to check your coverage, most PPO plans accepted.</p>
          <div class="frow">
            <div><label for="nm">Full name</label><input id="nm" name="name" required /></div>
            <div><label for="ph">Phone</label><input id="ph" name="phone" type="tel" required /></div>
          </div>
          <label class="optin"><input type="checkbox" required style="width:auto;margin:2px 0 0;" /> <span>I agree to receive calls/texts from Regain Hope Detox and Recovery Center about treatment. Msg &amp; data rates may apply. Reply STOP to opt out. Consent is not a condition of treatment.</span></label>
          <button type="submit">Request My Callback</button>
          <p class="hipaa">🔒 Your information is private and confidential.</p>
        </form>
      </div>
    ) : (
      <div class="hero-rev" data-rotate>
        <div class="hr-badge"><span class="stars">★★★★★</span> 5.0 on Google · 8 reviews</div>
        {reviews.map((r, i) => (
          <article class={`hrev${i === 0 ? ' active' : ''}`}>
            <div class="stars">★★★★★</div>
            <p>“{r.text}”</p>
            <div class="who">{r.who}</div>
          </article>
        ))}
        <div class="hr-foot">
          <a class="btn btn-gold" href={cta.href}>{cta.label}</a>
          <a class="hr-all" href={GBP} target="_blank" rel="noopener">See all reviews →</a>
        </div>
      </div>
    )}
  </div>
</section>

<script>
  // Rotate the spotlighted review every 5s; respect reduced-motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll('[data-rotate]').forEach((box) => {
    const items = Array.from(box.querySelectorAll('.hrev'));
    if (items.length < 2 || reduce) return;
    let i = 0;
    setInterval(() => {
      items[i].classList.remove('active');
      i = (i + 1) % items.length;
      items[i].classList.add('active');
    }, 5000);
  });

  // Lead capture (interim, until CallTrackingMetrics is connected).
  // Set FORM_ENDPOINT to a Formspree URL or a Google Apps Script web-app URL and
  // each submission (name + phone) is POSTed there, then the user lands on /thank-you/.
  // While it's empty, the form keeps its default behavior (GET -> /thank-you/), so nothing breaks.
  const FORM_ENDPOINT = 'https://script.google.com/macros/s/AKfycbx4tL7gvSbIURBwgOtGZypT7BGmD0ardwQpzt7KGUqpXCJtKlM3qk6HRY7-xCMISIqC/exec';
  document.querySelectorAll('form.hero-form').forEach((f) => {
    f.addEventListener('submit', async (e) => {
      if (!FORM_ENDPOINT) return;
      e.preventDefault();
      const btn = f.querySelector('button[type="submit"]');
      if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
      try {
        await fetch(FORM_ENDPOINT, { method: 'POST', body: new FormData(f) });
      } catch (_) {}
      window.location.href = '/thank-you/';
    });
  });
</script>
