---
// Insurance module — mid-page, uses the REAL carrier logos. Reusable on detail pages.
const insurers = [
  ['aetna', 'Aetna'], ['anthem', 'Anthem'], ['bcbs', 'Blue Cross Blue Shield'], ['cigna', 'Cigna'],
  ['united-healthcare', 'UnitedHealthcare'], ['highmark', 'HighMark'], ['tricare', 'TRICARE'], ['triwest', 'TriWest'],
];
---
<section class="bg-cream"><div class="container">
  <div class="sec-head"><span class="eyebrow">Insurance</span><h2>Your insurance may cover treatment</h2><p>Most PPO plans cover medical detox and residential care. As an out-of-network provider, we verify your benefits free in about 5 minutes, no obligation.</p></div>
  <div class="ins-strip">
    {insurers.map(([f, alt]) => <img src={`/images/logos/insurance/${f}.svg`} alt={`${alt} insurance accepted`} loading="lazy" />)}
  </div>
  <div style="text-align:center;"><a class="btn btn-primary" href="/admissions/verify-insurance/">Verify Your Benefits</a></div>
</div></section>
