---
import Divider from './Divider.astro';
import { team } from '../data/blog.js';
// Breaker module: the real clinical team (photos, names, roles). Links to each staff/author page.
export interface Props { bg?: 'white' | 'cream'; blurb?: boolean; }
const { bg = 'cream', blurb = true } = Astro.props;
---
<section class={bg === 'cream' ? 'bg-cream' : ''}><div class="container">
  <Divider />
  <div class="sec-head" style="margin-top:22px;"><span class="eyebrow">Meet the team</span><h2>The people who care for you</h2><p>A small, close-knit clinical team, on-site and personally involved in your care.</p></div>
  <div class="teamgrid">
    {team.map((m) => (
      <a class="tm" href={`/blog/author/${m.slug}/`}>
        <img src={m.photo} alt={m.name} width="108" height="108" loading="lazy" />
        <h3>{m.name}</h3>
        <span class="role">{m.role}</span>
        {blurb && <p>{m.short}</p>}
      </a>
    ))}
  </div>
  <p style="text-align:center;margin-top:28px;"><a href="/about-us/team/" class="btn btn-outline">Meet the full team →</a></p>
</div></section>
