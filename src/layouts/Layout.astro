---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  /** Page-specific JSON-LD (e.g. FAQPage, MedicalWebPage). Object or array. */
  schema?: Record<string, any> | Record<string, any>[];
  image?: string;
  noindex?: boolean;
}
const { title, description, schema, image = '/images/regain-05.jpeg', noindex = false } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

// Sitewide Organization / Local business schema — rendered on every page
const org = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  name: 'Regain Hope Detox and Recovery Center',
  url: 'https://www.regainhopedetox.com',
  telephone: '+1-818-281-2458',
  image: ogImage,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1134 N Lima St',
    addressLocality: 'Burbank',
    addressRegion: 'CA',
    postalCode: '91505',
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 34.1719189, longitude: -118.3451238 },
  medicalSpecialty: 'Addiction',
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '5.0', reviewCount: '8' },
  availableLanguage: ['English', 'Spanish', 'Korean'],
};

const jsonld = [org, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph / Twitter -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Regain Hope Detox and Recovery Center" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <!-- Floating Google reviews badge (sitewide, bottom-left) -->
  <a class="grbadge" href="https://maps.app.goo.gl/S3YvacbqJG8mVm457" target="_blank" rel="noopener" aria-label="Rated 5.0 on Google from 8 reviews">
    <span class="g">G</span>
    <span class="grtxt"><span class="grstars">★★★★★</span><b>5.0</b> · 8 reviews</span>
  </a>

  <!-- Mobile-only: turn the trust strip + insurance logos into continuous marquees
       (avoids the stacked look on small screens). Desktop and reduced-motion are untouched. -->
  <script>
    const isMobile = window.matchMedia('(max-width:760px)').matches;
    const reduce = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
    if (isMobile && !reduce) {
      document.querySelectorAll('.trust .container, .ins-strip').forEach((el) => {
        if (el.dataset.mq) return;
        el.dataset.mq = '1';
        const track = document.createElement('div');
        track.className = 'mq-track';
        while (el.firstChild) track.appendChild(el.firstChild);
        const clone = track.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        clone.classList.add('mq-clone');
        const move = document.createElement('div');
        move.className = 'mq-move';
        move.appendChild(track);
        move.appendChild(clone);
        el.appendChild(move);
        el.classList.add('mq');
      });
    }
  </script>
</body>
</html>
