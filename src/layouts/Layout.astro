---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  /** Page-specific JSON-LD (e.g. FAQPage, MedicalWebPage). Object or array. */
  schema?: Record<string, any> | Record<string, any>[];
  image?: string;
  noindex?: boolean;
}
const { title, description, schema, image = '/images/regain-05.jpeg', noindex = false } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

// Sitewide Organization / Local business schema — rendered on every page
const org = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  name: 'Regain Hope Detox and Recovery Center',
  url: 'https://www.regainhopedetox.com',
  telephone: '+1-818-281-2458',
  image: ogImage,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1134 N Lima St',
    addressLocality: 'Burbank',
    addressRegion: 'CA',
    postalCode: '91505',
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 34.1719189, longitude: -118.3451238 },
  medicalSpecialty: 'Addiction',
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '5.0', reviewCount: '8' },
  knowsLanguage: ['English', 'Spanish', 'Korean'],
};

const jsonld = [org, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-NRM7J7XP');</script>
  <!-- End Google Tag Manager -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph / Twitter -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Regain Hope Detox and Recovery Center" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Preload the hero (LCP) background so it isn't discovered late behind the CSS -->
  <link rel="preload" as="image" href="/images/regain-03.jpeg" />

  <!-- Self-hosted fonts: preload the critical weights (font preload needs crossorigin even same-origin) -->
  <link rel="preload" href="/fonts/fraunces-var.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/poppins-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/poppins-600.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NRM7J7XP" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <!-- Floating Google reviews badge (sitewide, bottom-left) -->
  <a class="grbadge" href="https://maps.app.goo.gl/S3YvacbqJG8mVm457" target="_blank" rel="noopener" aria-label="Rated 5.0 on Google from 8 reviews">
    <span class="g">G</span>
    <span class="grtxt"><span class="grstars">★★★★★</span><b>5.0</b> · 8 reviews</span>
  </a>

  <!-- Mobile-only: turn the trust strip + insurance logos into continuous marquees
       (avoids the stacked look on small screens). Desktop and reduced-motion are untouched. -->
  <script>
    const isMobile = window.matchMedia('(max-width:760px)').matches;
    const reduce = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
    if (isMobile && !reduce) {
      document.querySelectorAll('.trust .container, .ins-strip').forEach((el) => {
        if (el.dataset.mq) return;
        el.dataset.mq = '1';
        const track = document.createElement('div');
        track.className = 'mq-track';
        while (el.firstChild) track.appendChild(el.firstChild);
        const clone = track.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        clone.classList.add('mq-clone');
        const move = document.createElement('div');
        move.className = 'mq-move';
        move.appendChild(track);
        move.appendChild(clone);
        el.appendChild(move);
        el.classList.add('mq');
        // The cloned half sits off-screen inside an overflow:hidden box and is only
        // revealed by the transform, so lazy-loading never fires for it — leaving
        // zero-width gaps in the loop. Force every logo in the marquee to load now.
        el.querySelectorAll('img').forEach((img) => {
          if (img.complete && img.naturalWidth) return;
          const src = img.getAttribute('src');
          img.removeAttribute('loading');
          if (src) img.setAttribute('src', src);
        });
      });
    }
  </script>
</body>
</html>
