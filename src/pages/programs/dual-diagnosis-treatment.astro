---
import Layout from '../../layouts/Layout.astro';
import TeamStrip from '../../components/TeamStrip.astro';
import Reviews from '../../components/Reviews.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import InsuranceBanner from '../../components/InsuranceBanner.astro';

const faqs = [
  { q: 'Can a mental health disorder lead to addiction?', a: 'Yes, many people use substances to cope with anxiety, depression, or trauma, which can develop into a substance use disorder over time.' },
  { q: 'How common are co-occurring disorders?', a: 'Very common, roughly half of people with a mental health disorder also experience a substance use disorder at some point in their lives.' },
  { q: 'What are the signs of a co-occurring disorder?', a: 'Using substances to manage mood or sleep, mental health symptoms worsening when you stop using, and prior treatment that addressed only one condition and didn\'t hold.' },
  { q: 'How do I help a loved one with a dual diagnosis?', a: 'Encourage an integrated assessment, avoid enabling, and call an admissions team that can explain options and verify insurance, we walk families through every step.' },
  { q: 'Do you treat mental health and addiction at the same time?', a: 'Yes, that is the definition of integrated dual diagnosis care, with in-house psychiatry, medical care, and therapy working together on one plan.' },
  { q: 'Does insurance cover dual diagnosis treatment?', a: 'Most PPO plans do. As an out-of-network provider, we verify your benefits for free before you commit.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Dual Diagnosis Treatment in Los Angeles', about: { '@type': 'MedicalCondition', name: 'Co-occurring Disorders' }, reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };

const pairs = [
  ['Depression', '+ alcohol or substance use', 'cloud'],
  ['Anxiety disorders', '+ stimulant or substance use', 'brain'],
  ['Trauma & PTSD', '+ opioid or substance use', 'shieldalert'],
  ['Bipolar disorder', '+ alcohol or substance use', 'wave'],
];
const GBP = 'https://maps.app.goo.gl/S3YvacbqJG8mVm457';
---
<Layout
  title="Dual Diagnosis Treatment LA | Regain Hope Detox and Recovery Center"
  description="Integrated dual diagnosis treatment in the Los Angeles area: addiction, mental health, and physical health treated together by on-site physicians. PPO accepted. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <!-- HERO -->
  <Hero
    variant="form"
    eyebrow="Programs · Serving Los Angeles · 24/7"
    title="Dual Diagnosis Treatment in the Los Angeles Area"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['Physician-owned & operated', 'In-house psychiatry & medical care', 'Couples accepted & treated together', 'Care in English, Spanish & Korean']}
  />

  <!-- TRUST -->
  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Two physicians on-site daily</span>
  </div></div>

  <!-- WHAT IS (white) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>What is dual diagnosis?</h2>
    <p><b>Dual diagnosis, also called co-occurring disorders, is when a person has both a substance use disorder and a mental health condition at the same time,</b> such as depression with alcohol use or PTSD with opioid use. The two feed each other: people often drink or use to quiet anxiety, trauma, or depression, while substances deepen those same symptoms. Lasting recovery requires treating both at once.</p>
    <p>At Regain Hope Detox and Recovery Center, that integrated care goes one step further. Because our lead physician is trained in internal and family medicine, we also address the <b>physical health</b> that addiction and mental illness so often erode.</p>
  </div></section>

  <ImageFeature
    bg="cream"
    image="/images/stock/co-occurring.webp"
    alt="A client in a one-on-one therapy session"
    side="left"
    eyebrow="Both at once"
    title="One team, one coordinated plan"
    body="When the same team treats your addiction and your mental health together, nothing falls through the cracks, and recovery finally holds."
    points={[['brain', 'In-house psychiatry'], ['stethoscope', 'Physician-led medical care'], ['chat', 'Integrated therapy']]}
  />

  <!-- ★ CITED PREVALENCE STAT (caoba) -->
  <!-- NOTE: confirm exact SAMHSA figure + add citation link before publish -->
  <section class="bigstat"><div class="container">
    <div class="num">~50%</div>
    <p>About half of people who experience a mental health disorder will also experience a substance use disorder in their lifetime, and vice versa. Co-occurring disorders are common, treatable, and nothing to be ashamed of.</p>
    <div class="src">Source: SAMHSA</div>
  </div></section>

  <!-- SIGNS + WHY (merged, white) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>Signs you may be dealing with both</h2>
    <p>Dual diagnosis can look like:</p>
    <ul>
      <li>Using alcohol or drugs to cope with anxiety, depression, trauma, or sleep</li>
      <li>Mental health symptoms that worsen when you try to stop using</li>
      <li>Past treatment that addressed only the addiction, or only the mental health, and didn't hold</li>
      <li>Mood swings, isolation, or hopelessness alongside substance use</li>
    </ul>
    <h3>Why addiction and mental health must be treated together</h3>
    <p>If that sounds familiar, integrated treatment is designed for exactly this. Treating addiction while ignoring the mental health driving it, or treating mental health without addressing the substance use, usually leads back to relapse. <b>Integrated treatment</b> means one coordinated team and one plan, addressing both conditions at the same time. At Regain Hope Detox and Recovery Center, the same physicians who manage your detox and medical care work alongside psychiatry and therapy, so nothing falls through the cracks.</p>
  </div></section>

  <!-- ★ THE WEDGE — whole-person, 3 pillars (cream) -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">The difference</span><h2>We treat all three, not just two</h2><p>Most dual diagnosis programs treat two legs of the stool. Because Regain Hope Detox and Recovery Center is owned by physicians and includes in-house psychiatry, we care for all three, in person, every day.</p></div>
    <div class="grid3">
      <div class="pcard"><div class="ico"><Icon name="brain" /></div><h3>Mental health</h3><p>In-house psychiatry and therapy for depression, anxiety, trauma, and more.</p></div>
      <div class="pcard"><div class="ico"><Icon name="stethoscope" /></div><h3>Physical health</h3><p>A physician trained in internal &amp; family medicine coordinates the medical conditions addiction leaves behind.</p></div>
      <div class="pcard"><div class="ico"><Icon name="cycle" /></div><h3>Addiction</h3><p>Medical detox, residential care, and medication-assisted treatment to break the cycle.</p></div>
    </div>
  </div></section>

  <ImageFeature
    bg="white"
    image="/images/stock/holistic-home.webp"
    alt="A supportive group session"
    side="right"
    eyebrow="You belong here"
    title="Treated as a whole person, never a diagnosis"
    body="Co-occurring conditions are common, treatable, and nothing to be ashamed of. Here, you're surrounded by people and a team that see all of you."
    points={[['heart', 'Whole-person care'], ['users', 'Group & peer support'], ['family', 'Family welcomed in']]}
  />

  <!-- CO-OCCURRING CONDITIONS (cream) -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">What We Treat</span><h2>Co-occurring conditions we treat</h2></div>
    <div class="grid2" style="max-width:920px;margin:0 auto;">
      {pairs.map(([cond, sub, ico]) => (
        <div class="pcard"><div class="ico"><Icon name={ico} /></div><h3>{cond}</h3><p>{sub}</p></div>
      ))}
    </div>
    <p style="text-align:center;margin-top:24px;"><a href="/what-we-treat/" class="btn btn-outline">See all conditions &amp; substances →</a></p>
  </div></section>

  <!-- HOW WE TREAT (centered diagram, white) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Our approach</span><h2>How we treat dual diagnosis</h2><p>Care begins with a full medical and psychiatric assessment, then a personalized, integrated plan.</p></div>
    <div class="subhub">
      <div class="hub wide">Integrated<br />Dual-Diagnosis Care</div>
      <div class="subgrid">
        <div class="subtile"><span class="ic"><Icon name="clipboard" /></span><span class="nm">Medical &amp; psychiatric assessment</span></div>
        <div class="subtile"><span class="ic"><Icon name="brain" /></span><span class="nm">In-house psychiatry &amp; medication management</span></div>
        <div class="subtile"><span class="ic"><Icon name="users" /></span><span class="nm">Individual &amp; group therapy</span></div>
        <div class="subtile"><span class="ic"><Icon name="chat" /></span><span class="nm">CBT, DBT skills &amp; trauma-informed therapy</span></div>
        <div class="subtile"><span class="ic"><Icon name="mat" /></span><span class="nm">Medication-assisted treatment (MAT)</span></div>
        <div class="subtile"><span class="ic"><Icon name="stethoscope" /></span><span class="nm">Whole-person medical coordination</span></div>
      </div>
    </div>
    <p style="text-align:center;margin-top:30px;color:var(--muted);">Starts with <a href="/programs/medical-detox/">medical detox</a> and continues through <a href="/programs/residential-treatment/">residential treatment</a>.</p>
  </div></section>

  <!-- ★ FAMILY'S ROLE (split, cream) -->
  <section class="bg-cream"><div class="container">
    <div class="split">
      <div class="pic"><img src="/images/stock/family-therapy.webp" alt="A supportive family therapy session" loading="lazy" width="640" height="480" /></div>
      <div>
        <span class="eyebrow">For families</span>
        <h2 style="margin:8px 0 16px;">Healing happens with the people who love you</h2>
        <p>Co-occurring disorders affect the whole family. Our home-like setting and small size keep loved ones close, with family therapy available on request, and a team that follows up even after discharge.</p>
        <p style="margin-top:18px;"><a href="/admissions/for-families/" class="btn btn-outline">Help for families →</a></p>
      </div>
    </div>
  </div></section>

  <Reviews bg="white" />

  <!-- MODULE: Insurance (cream) -->
  <InsuranceBanner />

  <!-- FAQ (white) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Dual diagnosis FAQs</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <!-- CTA -->
  <TeamStrip bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>Treat the whole picture, and finally move forward</h2>
    <p>If addiction and mental health keep pulling you back, treating them together changes everything. One confidential call, answered 24/7, is the first step.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
