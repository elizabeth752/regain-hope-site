---
import Layout from '../../layouts/Layout.astro';
import TeamStrip from '../../components/TeamStrip.astro';
import Reviews from '../../components/Reviews.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import HomeNotClinic from '../../components/HomeNotClinic.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import InsuranceBanner from '../../components/InsuranceBanner.astro';

const faqs = [
  { q: 'How long does residential addiction treatment last?', a: 'Typically around 2–4 weeks after detox, set to your needs, and often followed by step-down care to protect your progress.' },
  { q: 'Do I need to complete detox first?', a: 'Usually yes, residential treatment begins once you are medically stable after detox.' },
  { q: 'How many people are in the program?', a: "It's a small, boutique residence. Care is personal and you're known by name, not treated as a number." },
  { q: 'Is medical care available during residential treatment?', a: 'Yes, two physicians provide in-person care daily, with 24/7 medical support throughout your stay.' },
  { q: 'Can my family be involved?', a: 'Yes, family therapy is available on request, and the home-like setting keeps loved ones connected.' },
  { q: 'What happens after residential treatment?', a: 'You step into a continuing-care plan with trusted referrals for IOP or sober living.' },
  { q: 'Does insurance cover residential rehab?', a: 'Most PPO plans do. As an out-of-network provider, we verify your benefits for free before you commit.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Residential Addiction Treatment in Los Angeles', about: { '@type': 'MedicalTherapy', name: 'Residential Addiction Treatment' }, reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };

const populations = [
  ['Professionals & Executives', '/who-we-help/professionals-executives/', 'Discreet, private care with a flexible technology policy so you can stay connected.', 'therapy-session', 'A professional resting peacefully during recovery'],
  ['LGBTQ+', '/who-we-help/lgbtq/', 'Affirming, judgment-free treatment that respects who you are.', 'support', 'A person feeling supported and at ease'],
  ['Veterans & First Responders', '/who-we-help/veterans-first-responders/', "Care for those who've carried heavy loads for others.", 'wellness-lifestyle', 'A man outdoors regaining strength in recovery'],
  ['Spanish & Korean Speakers', '/who-we-help/spanish-speaking/', 'Full residential care in English, Spanish, and Korean.', 'residential-day', 'A welcoming group in a bright, supportive setting'],
];
const gallery = [
  ['regain-05', 'Living room'], ['regain-07', 'Open-plan common area'], ['regain-10', 'Kitchen island'], ['regain-09', 'Lounge with fireplace'],
  ['regain-06', 'Dining area'], ['regain-12', 'Outdoor deck'], ['regain-14', 'Courtyard'], ['regain-02', 'Bathroom'],
];
const GBP = 'https://maps.app.goo.gl/S3YvacbqJG8mVm457';
---
<Layout
  title="Residential Rehab in Los Angeles | Regain Hope Detox and Recovery Center"
  description="Inpatient drug & alcohol rehab in the Los Angeles area. Physician-owned, boutique home setting, 24/7 in-person doctor care after detox. PPO accepted. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <!-- HERO (money page → consistent regain-03 bg + insurance form) -->
  <Hero
    variant="form"
    eyebrow="Programs · Serving Los Angeles · 24/7"
    title="Residential Addiction Treatment in the Los Angeles Area"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['Physician-owned & operated', 'Couples accepted & treated together', 'Stay connected: flexible device & technology policy', 'LGBTQ+ affirming · all genders welcome']}
  />

  <!-- TRUST -->
  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Two physicians on-site daily</span>
  </div></div>

  <!-- WHAT IS (clinical) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>What is residential addiction treatment?</h2>
    <p><b>Residential addiction treatment is live-in care where you stay at the facility 24/7 and receive structured therapy, medical support, and recovery skills, usually right after medical detox.</b> It's the difference between getting through withdrawal and actually building a sober life. Removed from the triggers and routines tied to using, you can focus fully on recovery in a safe, supportive environment.</p>
    <p>At Regain Hope Detox and Recovery Center, "residential" means a real home, a small, private residence in the Los Angeles area, run by the two physicians who own it and care for clients in person, daily.</p>
  </div></section>

  <ImageFeature
    bg="cream"
    image="/images/stock/aftercare.webp"
    alt="A supportive group connecting outdoors in recovery"
    side="left"
    eyebrow="You're not in it alone"
    title="Healing happens in community"
    body="Live-in care surrounds you with people who understand: peers walking the same road, and a small team that knows your name and your story."
    points={[['users', 'Group therapy & peer connection'], ['family', 'Family welcomed in'], ['heart', 'A team that treats you like family']]}
  />

  <!-- WHERE IT FITS (clinical + flow diagram) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">The continuum</span><h2>Where residential fits in your recovery</h2></div>
    <div class="flow">
      <div class="step"><div class="num">1</div><h4>Medical Detox</h4><p>Safely clear substances, about 5–10 days.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">2</div><h4>Residential</h4><p>Live-in therapy &amp; skill-building so sobriety lasts.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">3</div><h4>Continuing Care</h4><p>Step-down referrals for IOP or sober living.</p></div>
    </div>
    <p style="text-align:center;margin-top:26px;color:var(--muted);">Start with <a href="/programs/medical-detox/">medical detox</a>, then step down through <a href="/programs/continuing-care/">continuing care</a>.</p>
  </div></section>

  <!-- MODULE: Team (breaker variety — meet the physicians) -->

  <!-- HOME-NOT-CLINIC (flagship highlight — the home angle fits residential) -->
  <HomeNotClinic />

  <!-- A DAY (schedule) -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">Daily life</span><h2>What a day looks like in residential treatment</h2></div>
    <div class="daylist">
      <div class="row"><div class="ic"><Icon name="sunrise" /></div><div class="when">Mornings</div><div class="what">Medical check-in with the physicians, a breakfast cooked in-house, and individual or group therapy to set the day.</div></div>
      <div class="row"><div class="ic"><Icon name="sun" /></div><div class="when">Daytime</div><div class="what">Evidence-based therapy, CBT and individual counseling, alongside music therapy, yoga, and mindfulness.</div></div>
      <div class="row"><div class="ic"><Icon name="sunset" /></div><div class="when">Afternoons</div><div class="what">Wellness and movement: on-site fitness, walks and hikes, and time outdoors in the garden and courtyard.</div></div>
      <div class="row"><div class="ic"><Icon name="moon" /></div><div class="when">Evenings</div><div class="what">Peer connection, reflection, and rest in a comfortable, private home-like setting.</div></div>
    </div>
  </div></section>

  <!-- ★ POPULATIONS (image cards) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Who heals here</span><h2>Personalized care for who you are</h2><p>A small, physician-owned program can do what big centers can't: tailor care to your life.</p></div>
    <div class="grid2" style="max-width:920px;margin:0 auto;">
      {populations.map(([t, href, d, img, alt]) => (
        <div class="imgcard">
          <img class="ph" src={`/images/stock/${img}.webp`} alt={alt} loading="lazy" width="600" height="375" />
          <div class="bd"><h3>{t}</h3><p>{d}</p><a class="more" href={href}>Learn more →</a></div>
        </div>
      ))}
    </div>
    <p style="text-align:center;margin-top:22px;color:var(--muted);">We also welcome couples and court-involved clients, without judgment.</p>
  </div></section>

  <!-- MODULE: Insurance -->
  <InsuranceBanner />

  <!-- INSIDE THE PROGRAM — Medical & clinical (centered diagram) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Inside the program</span><h2>Medical &amp; clinical care</h2><p>Every residential stay is built around real, daily medical care, coordinated by the two physicians who own the program.</p></div>
    <div class="subhub">
      <div class="hub wide">Medical &amp;<br />Clinical Care</div>
      <div class="subgrid">
        <div class="subtile"><span class="ic"><Icon name="stethoscope" /></span><span class="nm">24/7 physician-supervised care</span></div>
        <div class="subtile"><span class="ic"><Icon name="chat" /></span><span class="nm">Individual counseling</span></div>
        <div class="subtile"><span class="ic"><Icon name="users" /></span><span class="nm">Group therapy</span></div>
        <div class="subtile"><span class="ic"><Icon name="brain" /></span><span class="nm">CBT &amp; motivational interviewing</span></div>
        <div class="subtile"><span class="ic"><Icon name="mat" /></span><span class="nm">Medication-assisted treatment</span></div>
        <div class="subtile"><span class="ic"><Icon name="dual" /></span><span class="nm">Dual-diagnosis support</span></div>
      </div>
    </div>
  </div></section>

  <!-- THERAPIES & COMFORTS (image left · icon-list right) -->
  <section class="bg-cream"><div class="container">
    <div class="split">
      <div class="pic"><img src="/images/stock/holistic-care.webp" alt="A man finding peace and renewal outdoors in recovery" loading="lazy" width="640" height="480" /></div>
      <div>
        <span class="eyebrow">Whole-person healing</span>
        <h2 style="margin:8px 0 22px;">Therapies &amp; comforts</h2>
        <ul class="icon-list">
          <li><span class="ic"><Icon name="music" /></span><div><h4>Music, art &amp; adventure therapy</h4><p>A weekly musician, art, and hikes toward the Hollywood sign.</p></div></li>
          <li><span class="ic"><Icon name="leaf" /></span><div><h4>Yoga &amp; mindfulness</h4><p>Meditation and movement to steady mind and body.</p></div></li>
          <li><span class="ic"><Icon name="activity" /></span><div><h4>On-site fitness &amp; hikes</h4><p>A gym, walking trails, and time in the foothills.</p></div></li>
          <li><span class="ic"><Icon name="meal" /></span><div><h4>Home-cooked meals</h4><p>Nourishing food prepared fresh in the house.</p></div></li>
          <li><span class="ic"><Icon name="family" /></span><div><h4>Family therapy on request</h4><p>Couples and family sessions to heal together.</p></div></li>
          <li><span class="ic"><Icon name="globe" /></span><div><h4>Bilingual care</h4><p>Full treatment in English, Spanish &amp; Korean.</p></div></li>
        </ul>
      </div>
    </div>
  </div></section>

  <!-- HOW LONG (clinical) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>How long does residential treatment last?</h2>
    <p><b>Length of stay is set to your needs: typically around 2–4 weeks of residential care following detox,</b> with many clients continuing into local step-down care for months afterward to protect their progress. Because we're a small program, your timeline is a clinical decision made with your physicians, not a fixed package.</p>
  </div></section>

  <!-- ★ SOCAL SETTING (highlight) -->
  <section class="bg-cream"><div class="container">
    <div class="highlight">
      <div class="txt">
        <span class="eyebrow" style="color:var(--gold-deep)">The setting</span>
        <h2>Recovery in the heart of Southern California</h2>
        <p>Set in a quiet Burbank neighborhood with a private garden, water-feature courtyard, and sunny outdoor lounges, Regain Hope Detox and Recovery Center blends structured care with room to breathe. Wellness here moves outdoors: morning walks and hikes toward the Hollywood sign, fresh air, and the calm of Southern California's foothills.</p>
        <div class="row">Private garden &amp; courtyard · Outdoor lounges &amp; decks · Hillside hikes · On-site fitness</div>
      </div>
      <div class="img" role="img" aria-label="Sunny patio and outdoor lounge" style="background-image:url('/images/regain-13.jpeg')"></div>
    </div>
  </div></section>

  <!-- CONDITIONS (two diagrams side by side) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">What We Treat</span><h2>What we treat in residential care</h2></div>
    <div class="dual-diagram">
      <div class="diagram">
        <span class="dh">Substances</span>
        <div class="dt">
          <div class="tile"><span class="ic"><Icon name="alcohol" /></span><span class="nm">Alcohol</span></div>
          <div class="tile"><span class="ic"><Icon name="opioids" /></span><span class="nm">Opioids &amp; Fentanyl</span></div>
          <div class="tile"><span class="ic"><Icon name="benzodiazepines" /></span><span class="nm">Benzodiazepines</span></div>
          <div class="tile"><span class="ic"><Icon name="stimulants" /></span><span class="nm">Stimulants</span></div>
          <div class="tile"><span class="ic"><Icon name="prescription" /></span><span class="nm">Prescription Drugs</span></div>
          <div class="tile"><span class="ic"><Icon name="polysubstance" /></span><span class="nm">Polysubstance</span></div>
        </div>
      </div>
      <div class="diagram">
        <span class="dh">Co-occurring</span>
        <div class="dt">
          <div class="tile"><span class="ic"><Icon name="brain" /></span><span class="nm">Anxiety</span></div>
          <div class="tile"><span class="ic"><Icon name="cloud" /></span><span class="nm">Depression</span></div>
          <div class="tile"><span class="ic"><Icon name="shieldalert" /></span><span class="nm">Trauma &amp; PTSD</span></div>
          <div class="tile"><span class="ic"><Icon name="wave" /></span><span class="nm">Bipolar Disorder</span></div>
        </div>
        <p style="margin-top:18px;"><a href="/programs/dual-diagnosis-treatment/" class="btn btn-outline">Dual diagnosis →</a></p>
      </div>
    </div>
  </div></section>

  <!-- GALLERY -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">The home</span><h2>A residence designed for recovery</h2><p>Comfortable bedrooms, a renovated chef's kitchen, sunny common areas, and private outdoor lounges.</p></div>
    <div class="gallery">
      {gallery.map(([f, alt]) => <img src={`/images/${f}.jpeg`} alt={alt} loading="lazy" width="280" height="190" />)}
    </div>
  </div></section>

  <Reviews bg="white" />

  <!-- FAQ -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Residential treatment FAQs</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <!-- CTA -->
  <TeamStrip bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>A new life can start in a place that feels like home</h2>
    <p>Detox gets you stable. Residential treatment helps it last. One confidential call, answered 24/7, is the first step.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
