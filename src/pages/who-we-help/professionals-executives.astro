---
import Layout from '../../layouts/Layout.astro';
import Reviews from '../../components/Reviews.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import ScenarioHighlight from '../../components/ScenarioHighlight.astro';
import InsuranceBanner from '../../components/InsuranceBanner.astro';

const faqs = [
  { q: 'Can I keep working during treatment?', a: 'Within our flexible technology policy, yes, we balance staying reachable for genuine priorities with protecting the focus your recovery needs.' },
  { q: 'Is treatment private and discreet?', a: 'Yes, a small, physician-owned residence, not an institutional facility with a public lobby or a crowd.' },
  { q: 'How long will I be away?', a: 'Medical detox typically runs 5–10 days, with residential care after; we tailor the timeline to your situation and responsibilities.' },
  { q: "What about the health issues I've been ignoring?", a: 'Our physician-owners coordinate your whole-person medical care during treatment; addiction rarely travels alone, especially under chronic stress.' },
  { q: 'Will my insurance cover it?', a: 'Most PPO plans do. As an out-of-network provider, we verify your benefits for free and explain the numbers plainly.' },
  { q: 'Will anyone find out I am here?', a: 'Your care is confidential and HIPAA-protected; discretion is the nature of a small, private home.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Detox & Rehab for Professionals and Executives', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };

const fits = [
  ['chat', 'A flexible technology policy', 'Stay reachable for what genuinely can\'t wait, within a structure that still protects your recovery.'],
  ['home', 'Privacy by design', 'A small, family-run residence, not a sprawling facility with a crowd and a sign out front.'],
  ['stethoscope', 'Physician-owned, whole-person care', 'Two doctors provide in-person care daily and coordinate the health that stress has eroded.'],
  ['heart', 'Close to home and work', 'In Burbank, minutes from Glendale, the Valley, and the studios, not across the country.'],
];
const GBP = 'https://maps.app.goo.gl/S3YvacbqJG8mVm457';
---
<Layout
  title="Executive & Professional Detox/Rehab | Regain Hope Detox and Recovery Center"
  description="Discreet detox and rehab for executives and professionals in the Los Angeles area. Physician-owned, private setting, flexible technology policy to stay connected. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="For Professionals & Executives · Los Angeles · 24/7"
    title="Detox & Rehab for Professionals and Executives"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['Private & discreet', 'Flexible device & technology policy', 'Owned & run by two physicians', 'Minutes from Glendale & the Valley']}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Physician-owned</span>
  </div></div>

  <!-- THE CHALLENGE (white) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>When stepping away feels impossible</h2>
    <p>For high-functioning professionals and executives, the hardest part of getting help often isn't admitting there's a problem; it's the fear of what stepping away might cost. The deal that can't close without you. The team that depends on your decisions. The reputation you've spent years building. And underneath it all, the quiet worry that if anyone found out, everything could unravel.</p>
    <p>So capable people keep going, managing a growing dependence on alcohol or prescription medication the same way they manage everything else, until the cost of <i>not</i> getting help finally outweighs the fear. The truth is, you don't have to choose between your recovery and your responsibilities. The right program is built to protect both, and the longer it's put off, the higher the stakes climb for your health, your judgment, and the very career you're trying to protect.</p>
  </div></section>

  <!-- IMAGE FEATURE (cream) -->
  <ImageFeature
    bg="cream"
    image="/images/stock/therapy-session.webp"
    alt="A professional finding calm during recovery"
    side="left"
    eyebrow="Discreet by design"
    title="Privacy and flexibility aren't luxuries, they make treatment possible"
    body="Most people who put off treatment aren't in denial; they're worried about logistics and exposure. When privacy and flexibility are built in, the biggest barriers to getting help fall away."
    points={[['home', 'A private home, not a public facility'], ['chat', 'Reachable for genuine priorities'], ['stethoscope', 'Physician-led, whole-person care']]}
  />

  <!-- WHY IT MATTERS (white) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>Why "discreet" and "flexible" change everything</h2>
    <p>A large facility with a public lobby, a rigid no-contact policy, and a one-size-fits-all schedule simply doesn't work for someone running a company or carrying a high-visibility role. When privacy and flexibility are part of the program, people actually come in, instead of waiting until a crisis forces the issue. Getting help early is not only easier; it's far better for your health, your career, and the people who depend on you.</p>
    <p>There's also the matter of trust. Executives are used to being the most capable person in the room, and handing over control, even to a doctor, can feel foreign. A small program where you actually know the two physicians treating you, and they know you, makes that trust possible. You're not handed between shifts of staff who've skimmed your chart; you're cared for by the people who own the program and answer for it personally.</p>
  </div></section>

  <!-- HOW WE FIT (cream cards) -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">The difference</span><h2>Discreet, physician-led care built for busy lives</h2></div>
    <div class="grid2" style="max-width:920px;margin:0 auto;">
      {fits.map(([ico, t, d]) => (
        <div class="pcard"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p></div>
      ))}
    </div>
  </div></section>

  <!-- WHAT WE OFFER (white) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>Your care, your terms</h2>
    <p>A complete, physician-led continuum in a private home: <a href="/programs/medical-detox/">medical detox</a> to stabilize you safely, <a href="/programs/residential-treatment/">residential treatment</a> and therapy to address what's underneath, <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis care</a> for the anxiety, depression, or burnout that so often accompany high-pressure careers, and <a href="/programs/medication-assisted-treatment/">medication-assisted treatment</a> to protect your sobriety afterward. Home-cooked meals, comfortable private spaces, and a calm setting round it out.</p>
    <p>What you won't find is an institutional feel: no fluorescent-lit wards, no crowded common rooms, no sense of being processed. The pace is calm and the setting is residential, closer to a quiet home than a hospital. For high-responsibility people who rarely let their guard down, that's often what finally makes it possible to exhale and do the real work of recovery.</p>
  </div></section>

  <!-- ★ SCENARIO HIGHLIGHT (cream) -->
  <ScenarioHighlight
    bg="cream"
    eyebrow="Recovery without losing your footing"
    title="Get well without disappearing"
    intro="Getting sober shouldn't mean torching your career or your privacy. Here's how care is built so you can step away just enough to heal, and come back stronger, not set back."
    badTitle="Most programs"
    bad={['A rigid no-contact policy', 'Months away, far from home', 'A public facility with a lobby and a crowd']}
    good={['A flexible technology policy', 'Minutes from Glendale, the Valley & the studios', 'A small, private, family-run residence']}
    momentLabel="When it matters"
    scenarios={[
      ['chat', "A priority that can't wait", 'Stay reachable within a structure that still protects your recovery.'],
      ['home', "Someone asks where you've been", 'Care happens quietly, by name, in a private home, not an institution.'],
      ['stethoscope', "The health you've ignored", 'Physician-owners coordinate the medical issues stress has been hiding.'],
    ]}
  />

  <Reviews bg="white" />

  <!-- INSURANCE (cream) -->
  <InsuranceBanner />

  <!-- FAQ (white) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Executive & professional treatment, FAQs</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <!-- CTA -->
  <section class="ctaband"><div class="container">
    <h2>Get well, without disappearing</h2>
    <p>One confidential call, answered 24/7, tells you what's possible, for your recovery and your responsibilities.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
