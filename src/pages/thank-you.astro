---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---
<Layout
  title="Thank You | Regain Hope Detox and Recovery Center"
  description="Thank you, we've received your request and will be in touch shortly."
  noindex={true}
>
  <section class="bg-cream"><div class="container" style="max-width:700px;text-align:center;">
    <div style="width:74px;height:74px;border-radius:50%;background:var(--gold-soft);color:var(--caoba-dark);display:flex;align-items:center;justify-content:center;margin:0 auto 22px;"><Icon name="check" size={38} /></div>
    <h1 style="font-size:clamp(30px,4vw,42px);">Thank you, we've got it</h1>
    <p class="lead" style="font-size:19px;color:var(--muted);margin:14px 0 0;">Your request is in. A member of our team will reach out shortly, and everything you shared is confidential.</p>
  </div></section>

  <section><div class="container rich" style="max-width:680px;">
    <h2 style="text-align:center;">What happens next</h2>
    <ol>
      <li><b>We verify your benefits</b>, usually the same day.</li>
      <li><b>We call you with the results</b>, what's covered, what (if anything) you'd owe, in plain English.</li>
      <li><b>You decide</b>, no pressure, no obligation.</li>
    </ol>
    <p style="text-align:center;margin-top:26px;">Prefer to talk now? We're here 24/7.</p>
    <div class="hero-cta" style="justify-content:center;margin-top:8px;">
      <a href="tel:+18182644388" class="btn btn-primary">📞 Call 24/7: (818) 264-4388</a>
      <a href="/" class="btn btn-outline">Back to home</a>
    </div>
    <div class="crisis" style="margin-top:30px;text-align:center;background:var(--cream);border-radius:12px;padding:16px 20px;font-size:14px;color:var(--muted);">In crisis? Call or text <b>988</b> (Suicide &amp; Crisis Lifeline) or <b>911</b>, available 24/7.</div>
  </div></section>
</Layout>
