---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import PhysicianLed from '../../components/PhysicianLed.astro';
import Reviews from '../../components/Reviews.astro';
import { team } from '../../data/blog.js';

const teamSchema = team.map((m) => ({ '@context': 'https://schema.org', '@type': 'Person', name: m.name, jobTitle: m.role, worksFor: { '@type': 'MedicalClinic', name: 'Regain Hope Detox and Recovery Center' } }));
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Meet the Team, Regain Hope Detox and Recovery Center', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };
---
<Layout
  title="Meet Our Team | Regain Hope Detox and Recovery Center"
  description="Meet the physician-led clinical team at Regain Hope Detox and Recovery Center in Burbank, CA, on-site, in person, and personally involved in your care."
  schema={[pageSchema, ...teamSchema]}
>
  <Hero
    variant="reviews"
    eyebrow="Meet the Team · Burbank, CA · 24/7"
    title="Meet the team behind Regain Hope"
    lead="Physician-owned and physician-led, with a close-knit clinical team who cares for you in person, every day."
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['Physician-owned, on-site daily', 'Whole-person, in-person care', 'English · Español · 한국어', 'A close-knit, family team']}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Physician-owned</span>
  </div></div>

  <!-- INTRO (white) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>The doctors are the owners, and they're here every day</h2>
    <p>Regain Hope Detox and Recovery Center is owned and run by two physicians who built the program around a belief that recovery deserves real medical care delivered with genuine warmth. Unlike larger facilities where a physician checks in remotely, our doctors are <b>on-site, in person, every day</b>, and a small, close-knit clinical team surrounds them.</p>
  </div></section>

  <!-- PROFILES (alternating white / cream) -->
  {team.map((m, i) => (
    <section class={i % 2 === 1 ? 'bg-cream' : ''}><div class="container">
      <div class="profile">
        <div class="pic"><img src={m.photo} alt={`${m.name}, ${m.role}`} width="400" height="400" loading="lazy" /></div>
        <div>
          <h2>{m.name}</h2>
          <div class="role">{m.role}</div>
          <div class="rich" style="margin-top:10px;">{m.bio.map((para) => <p>{para}</p>)}</div>
          <div class="langs">{m.langs.map((l) => <span>{l}</span>)}</div>
        </div>
      </div>
    </div></section>
  ))}

  <!-- ★ PHYSICIAN-LED (cream) -->
  <PhysicianLed bg="cream" />

  <section><div class="container rich" style="max-width:820px;text-align:center;">
    <p style="color:var(--muted);">A close-knit, largely family team, with care available in English, Spanish, and Korean, and a culture that treats every client like one of their own.</p>
  </div></section>

  <Reviews bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>Meet the people who'll care for you</h2>
    <p>The first call is with our team, confidential, judgment-free, and answered 24/7.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
