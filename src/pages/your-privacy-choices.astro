<Layout title="Your Privacy Choices | Regain Hope Detox and Recovery Center" description="Exercise your privacy choices, including the right to opt out of the sale or sharing of personal information." noindex={true}>
  <section class="minihero"><div class="container">
    <span class="eyebrow">Your Rights</span>
    <h1>Your Privacy Choices</h1>
  </div></section>
  <section><div class="container rich" style="max-width:820px;">
    <p>California residents (and others with similar rights) may request to <b>opt out of the sale or sharing of personal information</b> and to <b>limit the use of sensitive personal information</b>. Our full process for submitting and honoring these requests is being finalized and is under legal review.</p>
    <p>To make a privacy request now, contact us:</p>
    <ul>
      <li><b>Privacy:</b> <a href="mailto:privacy@regainhopedetox.com">privacy@regainhopedetox.com</a></li>
      <li><b>Phone:</b> <a href="tel:+18182812458">(818) 281-2458</a></li>
    </ul>
    <p>See our <a href="/privacy/">Privacy Policy</a> for more on how we handle your information.</p>
    <p style="color:var(--muted);font-size:14px;">Regain Hope Detox and Recovery Center, Inc. · 1134 N. Lima St., Burbank, CA 91505</p>
  </div></section>
</Layout>
