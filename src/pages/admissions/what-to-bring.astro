---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';

const faqs = [
  { q: 'What should I bring to rehab?', a: 'ID, insurance card, current medications in original bottles, about a week of comfortable clothes, alcohol-free toiletries, and a few comfort items.' },
  { q: 'Can I bring my phone or laptop?', a: 'Often yes, under our flexible technology policy, the team explains the specifics.' },
  { q: 'Are meals provided?', a: 'Yes, home-cooked meals are provided.' },
  { q: 'Can I bring my pet?', a: 'No, we are not a pet-friendly facility.' },
  { q: "What can't I bring?", a: 'Alcohol, drugs, weapons, and items containing alcohol; the team confirms the full list.' },
  { q: 'What if I forget something?', a: "Most essentials can be sorted out after you arrive. Don't let packing delay getting help." },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'What to Bring to Treatment', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };
---
<Layout
  title="What to Bring to Detox & Rehab | Regain Hope Detox and Recovery Center"
  description="A simple packing list for detox and rehab: what to bring, what to leave at home, and what's provided. Everything you need to prepare for treatment. Call (818) 264-4388."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="reviews"
    eyebrow="Admissions · Serving Los Angeles · 24/7"
    title="What to Bring to Treatment"
    lead="Packing for treatment is simpler than packing for vacation. Here's what to bring, what to leave home, and what we provide, so you can focus on what matters."
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['Home-cooked meals provided', 'Comfortable home setting', 'Flexible technology policy', 'Just bring the essentials']}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Physician-owned</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>What to bring</h2>
    <ul>
      <li><b>Photo ID</b> and your <b>insurance card</b></li>
      <li><b>Current medications</b> in their original, labeled bottles, for the medical team to review</li>
      <li><b>Comfortable, casual clothing</b> for about a week (laundry is typically available), layers for varying temperatures</li>
      <li><b>Alcohol-free toiletries</b>, toothbrush, toothpaste, shampoo, deodorant, and the like</li>
      <li><b>A few comfort items</b>, photos, a journal, a book</li>
      <li><b>Phone or laptop</b> if you need to stay connected, see our flexible technology policy</li>
    </ul>
    <p>Keep it simple. A small amount of personal items is all you need.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>What we provide (so you don't need to pack it)</h2>
    <p><b>Home-cooked meals</b>, comfortable common spaces, and a private, residential setting. You're coming to a home. Bring the essentials, and we'll take care of the rest.</p>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>What not to bring</h2>
    <ul>
      <li>Alcohol, drugs, or any unapproved substances</li>
      <li>Weapons of any kind</li>
      <li>Pets, we are not a pet-friendly facility</li>
      <li>Valuables you'd rather not travel with</li>
      <li>Anything containing alcohol (such as certain mouthwashes or toiletries)</li>
    </ul>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>A few Regain Hope specifics</h2>
    <ul>
      <li><b>Staying connected:</b> we offer a flexible technology policy, helpful for working professionals. The team will explain exactly how it works.</li>
      <li><b>Meals &amp; dietary needs:</b> meals are provided; let us know about any dietary needs in advance.</li>
      <li><b>Anything specific?</b> Just ask when you call. We'll tell you exactly what to bring, including our current smoking and vaping policy.</li>
    </ul>
  </div></section>

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>What to bring, frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <section class="ctaband"><div class="container">
    <h2>Have a packing question? Just ask.</h2>
    <p>Don't let packing delay getting help. Call us 24/7 and we'll walk you through it.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
