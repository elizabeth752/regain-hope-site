---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  { q: 'How do I get started with treatment?', a: 'Call us 24/7 at (818) 281-2458. We verify your insurance, complete a brief medical assessment, and admit you, often the same day.' },
  { q: 'Can I be admitted the same day?', a: 'Often, yes, once benefits are verified and the assessment is done. We move as quickly as is safe and appropriate for you.' },
  { q: 'What does it cost to call or verify?', a: 'Nothing. The call and the insurance verification are free and carry no obligation.' },
  { q: 'Do you help with travel if I am out of the area?', a: 'Yes, if you are coming from out of the area, we help arrange travel and a smooth arrival.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Admissions: How to Get Started', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };

const resources = [
  ['clipboard', 'What to Expect', 'Your first day and first week, step by step.', '/admissions/what-to-expect/'],
  ['home', 'What to Bring', 'A simple packing list, and what we provide.', '/admissions/what-to-bring/'],
  ['check', 'Verify Insurance', 'A free, no-obligation benefits check.', '/admissions/verify-insurance/'],
  ['family', 'For Families', 'How to help someone you love take the next step.', '/admissions/for-families/'],
];
---
<Layout
  title="Admissions: How to Get Started | Regain Hope Detox and Recovery Center"
  description="Starting treatment is simple: call, verify your insurance, complete an assessment, and admit, often the same day. 24/7 admissions for the Los Angeles area. Call (818) 281-2458."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="Admissions · Serving Los Angeles · 24/7"
    title="Admissions: Starting Treatment Is Simpler Than You Think"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['24/7 admissions', 'Often same-day', 'Free insurance verification', 'Owned & run by two physicians']}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Physician-owned</span>
  </div></div>

  <!-- 4 STEPS (white) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">The process</span><h2>How admission works, in 4 steps</h2></div>
    <div class="flow">
      <div class="step"><div class="num">1</div><h4>Call us, 24/7</h4><p>A confidential conversation, no pressure, just answers.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">2</div><h4>Verify insurance</h4><p>A free, fast benefits check tells you what's covered.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">3</div><h4>Medical assessment</h4><p>A physician reviews your history and builds your plan.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">4</div><h4>Admission</h4><p>Often the same day; we help arrange travel if needed.</p></div>
    </div>
    <p style="text-align:center;margin-top:26px;"><a href="/admissions/verify-insurance/" class="btn btn-primary">Verify Your Insurance</a></p>
  </div></section>

  <!-- RESOURCES (cream) -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">Prepare</span><h2>Everything you need to get ready</h2></div>
    <div class="grid2" style="max-width:920px;margin:0 auto;">
      {resources.map(([ico, t, d, href]) => (
        <a class="pcard" href={href} style="text-decoration:none;display:block;"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p><span class="more">Learn more →</span></a>
      ))}
    </div>
  </div></section>

  <!-- REASSURANCE (white, ImageFeature) -->
  <ImageFeature
    bg="white"
    image="/images/stock/admissions-assessment.webp"
    alt="An admissions specialist walking someone through the process"
    side="right"
    eyebrow="No pressure, ever"
    title="You don't have to have it all figured out"
    body="Most people who call aren't sure what to ask or what comes next. That's exactly what we're here for. We walk you through every step, in plain language, on your timeline."
    points={[['chat', 'A free, confidential first call'], ['heart', 'Judgment-free guidance'], ['clipboard', 'We handle the logistics']]}
  />

  <Reviews bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>The first step is a phone call</h2>
    <p>Confidential, judgment-free, and answered 24/7 by people who care.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
