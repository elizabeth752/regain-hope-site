---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  { q: 'How long does verification take?', a: 'Usually about 5 minutes to submit, and often same-day for results.' },
  { q: 'Does it cost anything?', a: "No — it's completely free." },
  { q: 'Am I committing to treatment?', a: 'No — verification carries zero obligation. Many people verify just to understand their options.' },
  { q: 'Is my information private?', a: "Yes — it's confidential and HIPAA-protected; we never share it." },
  { q: 'What insurance do you accept?', a: 'Most major PPO plans, as an out-of-network provider. See our insurance page for the carriers we work with.' },
  { q: "What if I don't have insurance?", a: "Ask about private-pay options — call and we'll talk through what's available." },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Verify Your Insurance Benefits', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };
---
<Layout
  title="Verify Your Insurance for Detox & Rehab | Regain Hope Detox and Recovery Center"
  description="Free, confidential insurance verification for detox & rehab. Most PPO plans accepted. Takes about 5 minutes, no obligation. Verify online or call (818) 281-2458."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="Free · Confidential · No Obligation"
    title="Verify Your Insurance Benefits"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['100% confidential', 'Free & no obligation', 'Most PPO plans accepted', 'Results often same-day']}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Most major PPO plans accepted</span>
  </div></div>

  <!-- WHAT HAPPENS NEXT (white, flow) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">What happens next</span><h2>What happens after you submit</h2></div>
    <div class="flow">
      <div class="step"><div class="num">1</div><h4>We verify your benefits</h4><p>Our team confirms your coverage, usually the same day.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">2</div><h4>We call you</h4><p>What's covered, what (if anything) you'd owe, in plain English.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">3</div><h4>You decide</h4><p>No pressure, no obligation — many verify just to know their options.</p></div>
    </div>
  </div></section>

  <!-- TRUST BAND (cream, ImageFeature) -->
  <ImageFeature
    bg="cream"
    image="/images/stock/support.webp"
    alt="A person feeling reassured after checking their coverage"
    side="left"
    eyebrow="Clarity, not a commitment"
    title="Free. Confidential. No obligation."
    body="Verifying your benefits doesn't commit you to anything — it just gives you clarity. Whatever you decide, you'll know exactly where you stand."
    points={[['check', 'Completely free'], ['heart', '100% confidential & HIPAA-protected'], ['chat', 'Plain-English answers']]}
  />

  <!-- WHY VERIFY (white) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>Why a benefits check matters</h2>
    <p>Insurance is confusing, and no two plans are alike — coverage, deductibles, and limitations vary widely. A verification of benefits is the only way to get a real answer for <i>your</i> plan, and it costs nothing. Learn more about how coverage works on our <a href="/insurance/">insurance page</a>.</p>
  </div></section>

  <!-- FAQ (cream) -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Insurance verification — quick questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <Reviews bg="white" />

  <section class="ctaband"><div class="container">
    <h2>Get clarity in minutes</h2>
    <p>Submit the form above or call 24/7 — we'll handle the rest and explain your coverage in plain English.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="tel:+18182812458" class="btn btn-gold">📞 Call 24/7 — (818) 281-2458</a></div>
  </div></section>
</Layout>
