---
import Layout from '../../layouts/Layout.astro';
import TeamStrip from '../../components/TeamStrip.astro';
import Reviews from '../../components/Reviews.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import PhysicianLed from '../../components/PhysicianLed.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import InsuranceBanner from '../../components/InsuranceBanner.astro';

const faqs = [
  { q: 'Is opioid withdrawal dangerous?', a: "It's rarely fatal on its own but intensely uncomfortable, and overdose risk spikes after a relapse. Medical detox is far safer and more humane." },
  { q: 'How long does opioid detox take?', a: 'Often around 5–10 days depending on the opioid and your history; your physician sets the plan.' },
  { q: 'Do you use methadone?', a: "No, Regain Hope Detox and Recovery Center isn't a methadone clinic. We lead with naltrexone/Vivitrol within physician-led detox and residential care." },
  { q: 'What is Vivitrol?', a: 'A monthly, non-narcotic naltrexone injection that blocks opioid effects and reduces cravings.' },
  { q: 'Do you treat fentanyl addiction?', a: 'Yes, fentanyl is an opioid; we provide medically supervised detox and treatment for it.' },
  { q: 'Does insurance cover opioid treatment?', a: 'Most PPO plans do. As an out-of-network provider, we verify your benefits for free.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Opioid & Fentanyl Detox in Los Angeles', about: { '@type': 'MedicalCondition', name: 'Opioid Use Disorder' }, reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };

const continuum = [
  ['detox', 'Medical Detox', 'Medically managed opioid withdrawal, 24/7.', '/programs/medical-detox/'],
  ['home', 'Residential Treatment', 'Therapy and skills in a home-like setting.', '/programs/residential-treatment/'],
  ['mat', 'Medication-Assisted Treatment', 'Naltrexone/Vivitrol to block opioids and reduce cravings.', '/programs/medication-assisted-treatment/'],
  ['dual', 'Dual-Diagnosis Care', 'Treating co-occurring depression, anxiety, or trauma.', '/programs/dual-diagnosis-treatment/'],
  ['heart', 'Continuing Care', 'Relapse-prevention planning + personal follow-up.', '/programs/continuing-care/'],
];
const NIDA = 'https://nida.nih.gov/research-topics/opioids';
const GBP = 'https://maps.app.goo.gl/S3YvacbqJG8mVm457';
---
<Layout
  title="Opioid & Fentanyl Detox in Los Angeles | Regain Hope Detox and Recovery Center"
  description="Physician-supervised opioid and fentanyl detox in the Los Angeles area. Medically managed withdrawal, MAT, and whole-person care for opioid use disorder. PPO accepted. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="What We Treat · Serving Los Angeles · 24/7"
    title="Opioid & Fentanyl Detox & Treatment in the Los Angeles Area"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['Physician-supervised, 24/7 medical detox', 'Naltrexone/Vivitrol started before discharge', 'Owned & run by two physicians', 'Care in English, Spanish & Korean']}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Two physicians on-site daily</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>What is opioid use disorder?</h2>
    <p><b>Opioid use disorder (OUD) is a chronic, treatable medical condition involving the compulsive use of opioids despite harmful consequences</b> (National Institute on Drug Abuse, NIDA). Opioids include prescription painkillers (such as oxycodone, hydrocodone, and morphine), heroin, and, increasingly, <b>fentanyl</b>, a synthetic opioid up to 50 times stronger than heroin that now drives the majority of overdose deaths in the U.S. OUD changes brain chemistry in ways that make stopping extraordinarily hard without help, which is why it's treated as a medical condition, not a choice.</p>
    <p>Left untreated, opioid use disorder carries a serious risk of overdose, especially in the fentanyl era, when the potency of the illicit supply is unpredictable from one use to the next. But it is also one of the most treatable substance use disorders: with medically supervised detox, FDA-approved medication, and genuine support, most people can stabilize and rebuild. The earlier treatment begins, the more options, and the more life, you protect.</p>
  </div></section>

  <ImageFeature
    bg="cream"
    image="/images/stock/support.webp"
    alt="A person feeling supported and at peace in recovery"
    side="left"
    eyebrow="There is a way through"
    title="Opioid recovery, made survivable"
    body="Opioid withdrawal is brutal enough to make people give up. With physicians on-site and medication to ease it, we make the hardest days bearable, and the next chapter possible."
    points={[['stethoscope', '24/7 physician supervision'], ['mat', 'Vivitrol to protect against relapse'], ['heart', 'Compassion, never judgment']]}
  />

  <section><div class="container rich" style="max-width:820px;">
    <h2>Signs of opioid use disorder</h2>
    <p>Common signs include:</p>
    <ul>
      <li>Using more, or longer, than intended</li>
      <li>Strong cravings to use</li>
      <li>Needing more to feel the same effect (tolerance)</li>
      <li>Withdrawal symptoms when not using</li>
      <li>Failed attempts to cut down or stop</li>
      <li>Neglecting responsibilities or relationships</li>
      <li>Continuing to use despite clear harm</li>
    </ul>
    <p>Physical <b>withdrawal</b> and <b>tolerance</b> alone don't mean addiction (they can occur with prescribed use), but combined with loss of control, they point to OUD.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Why opioid detox needs medical supervision</h2>
    <p>Opioid withdrawal is rarely life-threatening on its own, but it is <b>intensely painful</b> (muscle aches, nausea, vomiting, diarrhea, chills, insomnia, severe cravings), and that misery is exactly why most people relapse trying to detox alone. The greater danger is <b>overdose after a relapse</b>, because tolerance drops quickly during withdrawal. <a href="/programs/medical-detox/">Medical detox</a> makes the process far more comfortable and dramatically safer, with physicians on-site 24/7 and medication to ease symptoms.</p>
  </div></section>


  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">Our approach</span><h2>How we treat opioid addiction</h2></div>
    <div class="grid3">
      {continuum.map(([ico, t, d, href]) => (
        <a class="pcard" href={href} style="text-decoration:none;display:block;"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p><span class="more">Learn more →</span></a>
      ))}
    </div>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>MAT for opioid use disorder</h2>
    <p>NIDA recognizes FDA-approved medications for OUD, <b>buprenorphine, methadone, and naltrexone</b>, as effective, evidence-based care. At Regain Hope Detox and Recovery Center, our physicians lead with <b>naltrexone, including the long-acting injection Vivitrol</b>, which is non-narcotic and blocks the effects of opioids; we often start it <b>before discharge</b> to protect against relapse. We are <b>not a methadone clinic</b>. We provide <a href="/programs/medication-assisted-treatment/">medication-assisted treatment</a> within physician-led detox and residential care.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Opioids and co-occurring mental health</h2>
    <p>Opioid use very often overlaps with depression, anxiety, chronic pain, and trauma. Our integrated <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis care</a> treats these together rather than in isolation.</p>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>When to seek help for opioid use</h2>
    <p>With fentanyl in nearly the entire illicit opioid supply, the risk of a fatal overdose has never been higher, and there's no safe amount of time to wait. If you or someone you love is using opioids (prescription or illicit), can't stop despite wanting to, or is experiencing withdrawal between uses, reach out now. Treatment works, and the first call is free and confidential. <b>If someone is overdosing, call 911 and use naloxone (Narcan) if available.</b></p>
  </div></section>

  <PhysicianLed bg="cream" />

  <Reviews bg="white" />

  <InsuranceBanner />

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Opioid treatment, frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
    <p style="text-align:center;margin-top:26px;color:var(--muted);font-size:13px;">Clinical information on this page is informed by the <a href={NIDA} target="_blank" rel="noopener">National Institute on Drug Abuse (NIDA)</a>.</p>
  </div></section>

  <TeamStrip bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>Recovery from opioids starts with one call</h2>
    <p>Opioid withdrawal is safer and more humane with doctors who are actually there. One confidential call, answered 24/7, is the first step.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
