---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import PhysicianLed from '../../components/PhysicianLed.astro';
import InsuranceBanner from '../../components/InsuranceBanner.astro';

const faqs = [
  { q: 'What substances do you treat?', a: 'Alcohol, opioids and fentanyl, benzodiazepines, stimulants (meth and cocaine), prescription drugs, and polysubstance use, plus co-occurring mental health conditions.' },
  { q: 'Do you treat mental health alongside addiction?', a: 'Yes, many clients also live with anxiety, depression, or trauma. Our integrated dual-diagnosis care treats both at once.' },
  { q: 'Which withdrawals are dangerous to detox from alone?', a: 'Alcohol and benzodiazepine withdrawal can be life-threatening, and opioid withdrawal is severe, all are safest with 24/7 medical supervision.' },
  { q: 'Does insurance cover treatment?', a: 'Most PPO plans do. As an out-of-network provider, we verify your benefits for free before you commit.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'What We Treat, Addictions & Co-Occurring Disorders', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };

const substances = [
  ['alcohol', 'Alcohol', 'Medically supervised detox + treatment for alcohol use disorder.', '/what-we-treat/alcohol/'],
  ['opioids', 'Opioids & Fentanyl', 'Safe withdrawal management and MAT for opioid use disorder.', '/what-we-treat/opioids/'],
  ['benzodiazepines', 'Benzodiazepines', 'A carefully managed taper, benzo withdrawal can be dangerous.', '/what-we-treat/benzodiazepines/'],
  ['stimulants', 'Stimulants (Meth & Cocaine)', 'Detox and behavioral treatment for stimulant use.', '/what-we-treat/stimulants/'],
  ['prescription', 'Prescription Drugs', 'Treatment for misuse of painkillers, sedatives, and stimulants.', '/what-we-treat/prescription-drugs/'],
  ['polysubstance', 'Polysubstance', 'Coordinated care when more than one substance is involved.', '/what-we-treat/polysubstance/'],
];
---
<Layout
  title="What We Treat: Addictions & Co-Occurring Disorders | Regain Hope Detox and Recovery Center"
  description="Physician-led detox and treatment for alcohol, opioids, benzodiazepines, stimulants, and prescription drugs, plus co-occurring mental health, in the Los Angeles area. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <!-- HERO (navigational hub → reviews variant) -->
  <Hero
    variant="reviews"
    eyebrow="What We Treat · Serving Los Angeles · 24/7"
    title="What We Treat"
    lead="Physician-led detox and treatment for the substances that take hold, and the mental health that so often comes with them."
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['Physician-owned & operated', 'Couples accepted & treated together', 'Whole-person, medically-led care', 'Care in English, Spanish & Korean']}
  />

  <!-- TRUST -->
  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Two physicians on-site daily</span>
  </div></div>

  <!-- INTRO (white) -->
  <section><div class="container rich" style="max-width:820px;">
    <h2>Whole-person treatment for addiction</h2>
    <p>Addiction rarely involves just one substance or one struggle. At Regain Hope Detox and Recovery Center, our physician-owners treat the full range of substance use, safely managing withdrawal, then addressing the mental health, medical, and life factors underneath it. Every plan is built around the person, in a small, home-like setting.</p>
  </div></section>

  <!-- CHILD-CARDS GRID — substances (cream) -->
  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">Substances</span><h2>Substances we treat</h2></div>
    <div class="grid3">
      {substances.map(([ico, t, d, href]) => (
        <a class="pcard" href={href} style="text-decoration:none;display:block;"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p><span class="more">Learn more →</span></a>
      ))}
    </div>
  </div></section>

  <!-- CATEGORY VISUAL — continuum flow (white) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">How treatment works</span><h2>One physician-led continuum, in one home</h2></div>
    <div class="flow">
      <div class="step"><div class="num">1</div><h4>Medical Detox</h4><p>Safely manage withdrawal.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">2</div><h4>Residential</h4><p>Live-in therapy &amp; skills.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">3</div><h4>MAT</h4><p>Medication to prevent relapse.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">4</div><h4>Continuing Care</h4><p>Follow-up &amp; referrals.</p></div>
    </div>
    <p style="text-align:center;margin-top:26px;color:var(--muted);">Explore <a href="/programs/medical-detox/">medical detox</a>, <a href="/programs/residential-treatment/">residential treatment</a>, <a href="/programs/medication-assisted-treatment/">MAT</a>, and <a href="/programs/continuing-care/">continuing care</a>.</p>
  </div></section>

  <!-- CO-OCCURRING (stock ImageFeature, cream) -->
  <ImageFeature
    bg="cream"
    image="/images/stock/co-occurring.webp"
    alt="A client in a supportive one-on-one therapy session"
    side="right"
    eyebrow="Co-occurring conditions"
    title="Treating the struggle underneath the substance"
    body="Many people we treat are also living with anxiety, depression, or trauma, and each can fuel the other. Treating both together is the key to lasting recovery."
    points={[['brain', 'In-house psychiatry'], ['stethoscope', 'Physician-led medical care'], ['chat', 'Integrated dual-diagnosis therapy']]}
    cta={{ label: 'Explore dual diagnosis →', href: '/programs/dual-diagnosis-treatment/' }}
  />

  <!-- ★ PHYSICIAN-LED (white) -->
  <PhysicianLed />

  <!-- MODULE: Insurance (cream) -->
  <InsuranceBanner />

  <!-- FAQ (white) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>What we treat, frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <!-- CTA -->
  <section class="ctaband"><div class="container">
    <h2>Whatever you're facing, you don't have to face it alone</h2>
    <p>One free, confidential call with our team, answered 24/7, will help you find the right first step.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
