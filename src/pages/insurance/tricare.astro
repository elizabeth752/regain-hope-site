---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  {
    "q": "Does TRICARE cover detox and rehab?",
    "a": "Yes, TRICARE covers medically necessary detox and residential addiction treatment for eligible members; how it applies depends on your plan."
  },
  {
    "q": "Which TRICARE plan works best here?",
    "a": "TRICARE Select offers the most flexibility to use a TRICARE-authorized provider; TRICARE Prime typically requires referrals and authorization."
  },
  {
    "q": "Who administers TRICARE in the West Region?",
    "a": "TriWest administers TRICARE in the West Region, which includes California."
  },
  {
    "q": "Does TRICARE cover mental health and PTSD?",
    "a": "Yes, TRICARE covers mental health care, including service-related trauma and PTSD treated alongside addiction."
  },
  {
    "q": "How do I check my TRICARE benefits?",
    "a": "Call us or submit the form; we verify your specific TRICARE benefits for free and explain the path for your plan."
  }
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'TRICARE Coverage for Detox & Rehab in Los Angeles', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };
---
<Layout
  title="TRICARE Coverage for Detox & Rehab | Regain Hope Detox and Recovery Center"
  description="Does TRICARE cover detox and rehab in California? Regain Hope works with TRICARE out-of-network benefits, free, fast verification. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="TRICARE · Serving Los Angeles · 24/7"
    title="TRICARE Coverage for Detox & Rehab in the Los Angeles Area"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={["TRICARE Select accepted","Free benefits check","No obligation","Owned & run by two physicians"]}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Most major PPO plans accepted</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>What is TRICARE?</h2>
    <p>TRICARE is the health care program for U.S. uniformed service members, retirees, and their families. It includes several plan types, most notably <b>TRICARE Prime</b> (an HMO-style plan that uses assigned/network providers) and <b>TRICARE Select</b> (a fee-for-service plan that allows TRICARE-authorized non-network providers). In the <b>West Region</b>, TRICARE is administered by <b>TriWest</b>. TRICARE covers mental health and substance use treatment.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Does TRICARE cover detox and rehab?</h2>
    <p><b>Yes, TRICARE covers medically necessary detox and residential addiction treatment</b> for eligible members. How it applies depends on your plan: <b>TRICARE Select</b> offers the most flexibility to use a TRICARE-authorized provider, while <b>TRICARE Prime</b> typically requires referrals and authorization. We verify your specific TRICARE benefits for free and explain the path for your plan.</p>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Does TRICARE cover mental health and dual diagnosis treatment?</h2>
    <p>Yes, TRICARE covers mental health care, including service-related trauma and PTSD treated alongside addiction. See our <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis care</a>.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>What will I pay with TRICARE?</h2>
    <p>TRICARE cost-shares depend on your plan (Select vs Prime), your beneficiary category (active duty, retiree, family), and where you are in your plan year. We verify your specific TRICARE benefits for free and explain any cost-share before you commit.</p>
  </div></section>

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Quick & free</span><h2>Check your TRICARE coverage in minutes</h2></div>
    <div class="flow">
      <div class="step"><div class="num">1</div><h4>Share your TRICARE details</h4><p>Call or submit the form, it takes a minute.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">2</div><h4>We verify your benefits</h4><p>A free verification of benefits, usually same day.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">3</div><h4>Plain-English answer</h4><p>Exactly what your plan covers, no pressure.</p></div>
    </div>
    <p style="text-align:center;margin-top:26px;"><a href="/admissions/verify-insurance/" class="btn btn-primary">Verify Your TRICARE Benefits</a></p>
  </div></section>

  <ImageFeature
    bg="cream"
    image="/images/stock/holistic-care.webp"
    alt="A person reassured after a free benefits check"
    side="left"
    eyebrow="We do the legwork"
    title="Your TRICARE benefits, verified for free"
    body="You don't have to decode your policy alone. We call TRICARE, confirm what your plan covers, and explain it plainly, so the only thing you have to focus on is getting well."
    points={[['clipboard', 'Free verification of benefits'], ['stethoscope', 'Physician-led, whole-person care'], ['heart', 'No obligation, ever']]}
  />

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>TRICARE coverage, frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
    <p style="text-align:center;margin-top:22px;color:var(--muted);">See all the carriers we work with on our <a href="/insurance/">insurance page</a>.</p>
  </div></section>

  <Reviews bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>Find out what your TRICARE plan covers, free</h2>
    <p>A quick, confidential benefits check tells you exactly where you stand. Call 24/7 or verify online.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your TRICARE Benefits</a></div>
  </div></section>
</Layout>
