---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  {
    "q": "Does Anthem cover medical detox?",
    "a": "Most Anthem PPO plans cover medically necessary detox; we verify your specific benefits for free."
  },
  {
    "q": "Does Anthem cover residential (inpatient) rehab?",
    "a": "Generally yes for PPO plans when it is medically necessary — confirmed via verification of benefits."
  },
  {
    "q": "Is Regain Hope in-network with Anthem?",
    "a": "No — we are out-of-network and work with Anthem PPO out-of-network benefits."
  },
  {
    "q": "How do I check my Anthem coverage?",
    "a": "Call us or submit the form; we run a free, no-obligation verification of benefits."
  },
  {
    "q": "Will I owe a deductible with Anthem?",
    "a": "Likely some out-of-pocket cost depending on your plan and what you have met — we give you the real figures before you commit."
  },
  {
    "q": "Does Anthem cover dual diagnosis and mental health?",
    "a": "Most plans with behavioral health benefits do; we confirm during verification."
  }
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Anthem Blue Cross Coverage for Detox & Rehab in Los Angeles', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };
---
<Layout
  title="Anthem Blue Cross Coverage for Detox & Rehab | Regain Hope Detox and Recovery Center"
  description="Does Anthem Blue Cross cover detox and rehab in California? Regain Hope works with Anthem Blue Cross out-of-network benefits — free, fast verification. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="Anthem · Serving Los Angeles · 24/7"
    title="Anthem Blue Cross Coverage for Detox & Rehab in the Los Angeles Area"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={["Anthem PPO accepted (out-of-network)","Free 5-minute benefits check","No obligation","Owned & run by two physicians"]}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Most major PPO plans accepted</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>What is Anthem Blue Cross?</h2>
    <p>Anthem is one of the nation's largest health insurers and operates the <b>Blue Cross</b> plan in California and 13 other states (it's part of Elevance Health and a member of the Blue Cross Blue Shield federation). In California, when people say "Blue Cross," they usually mean Anthem Blue Cross. See also our <a href="/insurance/blue-cross-blue-shield/">Blue Cross Blue Shield</a> page. Anthem plans commonly include behavioral health benefits that can cover addiction treatment, depending on the plan.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Does Anthem Blue Cross cover detox and rehab?</h2>
    <p><b>Yes — most Anthem PPO plans cover medically necessary detox and residential addiction treatment.</b> Coverage specifics depend on your plan. Regain Hope Detox and Recovery Center works with Anthem <b>PPO out-of-network benefits</b>; we verify your exact coverage for free.</p>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Does Anthem cover mental health and dual diagnosis treatment?</h2>
    <p>Most Anthem plans with behavioral health benefits cover mental health care, including the <b>co-occurring anxiety, depression, and trauma</b> we treat alongside addiction. We confirm during verification. See our <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis care</a>.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Will I have a deductible or copay with Anthem?</h2>
    <p>Most likely, yes — most plans have a deductible and out-of-pocket maximum. Out-of-network deductibles are typically higher than in-network ones, but how much you have already met, your plan's reimbursement rate, and your out-of-pocket max all affect what you would actually pay. Rather than guess with ranges that may not match your plan, we give you the real numbers for your policy during a free verification.</p>
  </div></section>

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Quick & free</span><h2>Check your Anthem coverage in minutes</h2></div>
    <div class="flow">
      <div class="step"><div class="num">1</div><h4>Share your Anthem details</h4><p>Call or submit the form — it takes a minute.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">2</div><h4>We verify your benefits</h4><p>A free verification of benefits, usually same day.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">3</div><h4>Plain-English answer</h4><p>Exactly what your plan covers — no pressure.</p></div>
    </div>
    <p style="text-align:center;margin-top:26px;"><a href="/admissions/verify-insurance/" class="btn btn-primary">Verify Your Anthem Benefits</a></p>
  </div></section>

  <ImageFeature
    bg="cream"
    image="/images/stock/therapy-session.webp"
    alt="A person reassured after a free benefits check"
    side="left"
    eyebrow="We do the legwork"
    title="Your Anthem benefits, verified for free"
    body="You don't have to decode your policy alone. We call Anthem Blue Cross, confirm what your plan covers, and explain it plainly — so the only thing you have to focus on is getting well."
    points={[['clipboard', 'Free verification of benefits'], ['stethoscope', 'Physician-led, whole-person care'], ['heart', 'No obligation, ever']]}
  />

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Anthem Blue Cross coverage — frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
    <p style="text-align:center;margin-top:22px;color:var(--muted);">See all the carriers we work with on our <a href="/insurance/">insurance page</a>.</p>
  </div></section>

  <Reviews bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>Find out what your Anthem plan covers — free</h2>
    <p>A quick, confidential benefits check tells you exactly where you stand. Call 24/7 or verify online.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Anthem Benefits</a></div>
  </div></section>
</Layout>
