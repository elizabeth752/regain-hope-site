---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  { q: 'Does Aetna cover medical detox?', a: 'Most Aetna PPO plans cover medically necessary detox; we verify your specific benefits for free.' },
  { q: 'Does Aetna cover residential (inpatient) rehab?', a: 'Generally yes for PPO plans when it is medically necessary — confirmed via verification of benefits.' },
  { q: 'Is Regain Hope in-network with Aetna?', a: 'No — we are out-of-network and work with Aetna PPO out-of-network benefits.' },
  { q: 'Can I use an Aetna HMO here?', a: 'Usually not (HMOs lack out-of-network benefits), but a Single Case Agreement may be an option in some cases — ask us.' },
  { q: 'How do I check my Aetna coverage?', a: 'Call us or submit the form; we run a free, no-obligation verification of benefits.' },
  { q: 'Will I owe a deductible with Aetna?', a: 'Likely some out-of-pocket cost depending on your plan and what you have met — we give you the real figures before you commit.' },
  { q: 'Does Aetna cover dual diagnosis / mental health?', a: 'Most plans with behavioral health benefits do; we confirm during verification.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Aetna Coverage for Detox & Rehab in Los Angeles', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };
---
<Layout
  title="Aetna Coverage for Detox & Rehab | Regain Hope Detox and Recovery Center"
  description="Does Aetna cover detox and rehab in California? Most Aetna PPO plans do. Regain Hope works with Aetna out-of-network benefits — free, fast verification. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="Aetna · Serving Los Angeles · 24/7"
    title="Aetna Coverage for Detox & Rehab in the Los Angeles Area"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['Aetna PPO accepted (out-of-network)', 'Free 5-minute benefits check', 'No obligation', 'Owned & run by two physicians']}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Most major PPO plans accepted</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>What is Aetna insurance?</h2>
    <p>Aetna is one of the largest health insurers in the United States, offering employer-sponsored and individual plans including PPOs, HMOs, and others. Aetna plans commonly include behavioral health benefits that can cover addiction treatment — though, as with any insurer, the specifics depend on your individual plan.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Does Aetna cover detox and rehab?</h2>
    <p><b>Yes — most Aetna PPO plans cover medically necessary detox and residential addiction treatment.</b> Under federal parity laws, Aetna plans that include behavioral health benefits generally cover substance use treatment comparably to medical care. Regain Hope Detox and Recovery Center works with Aetna <b>PPO out-of-network benefits</b>; the exact coverage, deductible, and any limits depend on your specific Aetna policy — which we verify for free.</p>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Does Aetna cover mental health and dual diagnosis treatment?</h2>
    <p>Most Aetna plans with behavioral health benefits cover mental health care, including the <b>co-occurring anxiety, depression, and trauma</b> we treat alongside addiction. We'll confirm your specific <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis</a> coverage during verification.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Will I have a deductible or copay with Aetna?</h2>
    <p>Most likely, yes — most plans have a deductible and out-of-pocket maximum. Out-of-network deductibles are typically higher than in-network ones, but how much you've already met, your plan's reimbursement rate, and your out-of-pocket max all affect what you'd actually pay. Rather than guess with ranges that may not match your plan, we give you the real numbers for your policy during a free verification.</p>
  </div></section>

  <!-- VERIFY (white, flow) -->
  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Quick & free</span><h2>Check your Aetna coverage in minutes</h2></div>
    <div class="flow">
      <div class="step"><div class="num">1</div><h4>Share your Aetna details</h4><p>Call or submit the form — it takes a minute.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">2</div><h4>We verify your benefits</h4><p>A free verification of benefits, usually same day.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">3</div><h4>Plain-English answer</h4><p>Exactly what your Aetna plan covers — no pressure.</p></div>
    </div>
    <p style="text-align:center;margin-top:26px;"><a href="/admissions/verify-insurance/" class="btn btn-primary">Verify Your Aetna Benefits</a></p>
  </div></section>

  <ImageFeature
    bg="cream"
    image="/images/stock/therapy-session.webp"
    alt="A person reassured after a benefits check"
    side="left"
    eyebrow="We do the legwork"
    title="Your Aetna benefits, verified for free"
    body="You don't have to decode your policy alone. We call Aetna, confirm what your plan covers, and explain it plainly — so the only thing you have to focus on is getting well."
    points={[['clipboard', 'Free verification of benefits'], ['stethoscope', 'Physician-led, whole-person care'], ['heart', 'No obligation, ever']]}
  />

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Aetna coverage — frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
    <p style="text-align:center;margin-top:22px;color:var(--muted);">See all the carriers we work with on our <a href="/insurance/">insurance page</a>.</p>
  </div></section>

  <Reviews bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>Find out what your Aetna plan covers — free</h2>
    <p>A quick, confidential benefits check tells you exactly where you stand. Call 24/7 or verify online.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Aetna Benefits</a></div>
  </div></section>
</Layout>
