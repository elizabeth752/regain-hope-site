---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  {
    "q": "Is Regain Hope in-network with Kaiser?",
    "a": "No. Kaiser is an integrated, HMO-style plan; we are an out-of-network facility, so coverage is limited and decided case-by-case."
  },
  {
    "q": "Can I ever use Kaiser at an outside facility?",
    "a": "Sometimes, through a single case agreement, referral authorization, or continuity-of-care provisions, especially if Kaiser cannot provide timely or appropriate care. It is not guaranteed."
  },
  {
    "q": "How do I find out if there's a path forward?",
    "a": "Call us or submit the form; we verify your specific Kaiser plan for free and tell you honestly what's possible."
  },
  {
    "q": "Does Kaiser cover dual diagnosis and mental health?",
    "a": "Within Kaiser's system, yes; for outside care the same case-by-case rules apply. We'll explain during verification."
  }
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalWebPage', name: 'Kaiser Permanente Coverage for Detox & Rehab in Los Angeles', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };
---
<Layout
  title="Kaiser Permanente Coverage for Detox & Rehab | Regain Hope Detox and Recovery Center"
  description="Does Kaiser Permanente cover detox and rehab in California? Regain Hope works with Kaiser Permanente out-of-network benefits, free, fast verification. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="Kaiser · Serving Los Angeles · 24/7"
    title="Kaiser Permanente Coverage for Detox & Rehab in the Los Angeles Area"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={["Kaiser benefits checked case-by-case","Free, honest verification","No obligation","Owned & run by two physicians"]}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Most major PPO plans accepted</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>What is Kaiser Permanente?</h2>
    <p>Kaiser Permanente is an <b>integrated health system and insurer</b>, meaning Kaiser members generally receive care within Kaiser's own network of hospitals, clinics, and providers. This is different from a PPO, where you can use providers outside the network. For addiction treatment, Kaiser typically directs members to Kaiser-affiliated programs.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Does Kaiser cover detox and rehab outside Kaiser facilities?</h2>
    <p><b>It's limited and decided case-by-case.</b> Because Kaiser is an integrated, HMO-style plan, coverage at an out-of-network facility like ours isn't automatic the way it is with a PPO. In some situations, for example, when Kaiser can't provide timely or appropriate care, or through a single case agreement or referral authorization, outside treatment may be approved. We'll verify your specific Kaiser plan for free and tell you honestly whether there's a path forward, with no pressure either way.</p>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Does Kaiser cover mental health and dual diagnosis treatment?</h2>
    <p>Kaiser includes behavioral health benefits within its own system. If you're seeking care outside Kaiser, the same case-by-case rules apply, we'll explain your options during verification. See our <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis care</a>.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>What are my options with Kaiser?</h2>
    <p>If Kaiser can't provide timely or appropriate care, a path to outside treatment may exist through a referral authorization, a single case agreement, or continuity-of-care provisions. None are guaranteed, but we'll verify your specific Kaiser plan for free and tell you honestly whether there's a way forward.</p>
  </div></section>

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Quick & free</span><h2>Check your Kaiser coverage in minutes</h2></div>
    <div class="flow">
      <div class="step"><div class="num">1</div><h4>Share your Kaiser details</h4><p>Call or submit the form, it takes a minute.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">2</div><h4>We verify your benefits</h4><p>A free verification of benefits, usually same day.</p></div>
      <div class="arrow">→</div>
      <div class="step"><div class="num">3</div><h4>Plain-English answer</h4><p>Exactly what your plan covers, no pressure.</p></div>
    </div>
    <p style="text-align:center;margin-top:26px;"><a href="/admissions/verify-insurance/" class="btn btn-primary">Verify Your Kaiser Benefits</a></p>
  </div></section>

  <ImageFeature
    bg="cream"
    image="/images/stock/holistic-care.webp"
    alt="A person reassured after a free benefits check"
    side="left"
    eyebrow="We do the legwork"
    title="Your Kaiser benefits, verified for free"
    body="You don't have to decode your policy alone. We call Kaiser Permanente, confirm what your plan covers, and explain it plainly, so the only thing you have to focus on is getting well."
    points={[['clipboard', 'Free verification of benefits'], ['stethoscope', 'Physician-led, whole-person care'], ['heart', 'No obligation, ever']]}
  />

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Kaiser Permanente coverage, frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
    <p style="text-align:center;margin-top:22px;color:var(--muted);">See all the carriers we work with on our <a href="/insurance/">insurance page</a>.</p>
  </div></section>

  <Reviews bg="cream" />

  <section class="ctaband"><div class="container">
    <h2>Find out what your Kaiser plan covers, free</h2>
    <p>A quick, confidential benefits check tells you exactly where you stand. Call 24/7 or verify online.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Kaiser Benefits</a></div>
  </div></section>
</Layout>
