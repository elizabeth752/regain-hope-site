---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import InsuranceBanner from '../../components/InsuranceBanner.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  {
    "q": "Is there a private detox center near La Cañada Flintridge?",
    "a": "Yes, about 20 minutes away in Burbank, in a discreet residential setting."
  },
  {
    "q": "How far is it from La Cañada?",
    "a": "About 20 minutes via the SR-134."
  },
  {
    "q": "Is treatment private and discreet?",
    "a": "Yes, a small, home-like residence with no institutional setting."
  },
  {
    "q": "Can I stay reachable for work?",
    "a": "Yes, a flexible technology policy supports working professionals."
  },
  {
    "q": "Can my family stay involved?",
    "a": "Yes, the close location keeps family connected; family therapy on request."
  },
  {
    "q": "Why not detox at home?",
    "a": "Withdrawal can be medically dangerous and home is full of triggers; supervised detox nearby is safer and more effective."
  },
  {
    "q": "Does it accept PPO insurance?",
    "a": "Most PPO plans, as an out-of-network provider; benefits verified free."
  },
  {
    "q": "What substances can be detoxed from?",
    "a": "Alcohol, opioids and fentanyl, benzodiazepines, stimulants, prescription drugs, and polysubstance use."
  },
  {
    "q": "Is detox done with 24/7 medical supervision?",
    "a": "Yes, two physicians provide in-person care daily, with around-the-clock monitoring."
  },
  {
    "q": "Is care available in Spanish or Korean?",
    "a": "Yes, care is provided in English, Spanish, and Korean."
  }
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalClinic', name: 'Regain Hope Detox and Recovery Center', address: { '@type': 'PostalAddress', streetAddress: '1134 N Lima St', addressLocality: 'Burbank', addressRegion: 'CA', postalCode: '91505', addressCountry: 'US' }, telephone: '+1-818-264-4388', geo: { '@type': 'GeoCoordinates', latitude: 34.1719189, longitude: -118.3451238 }, areaServed: "La Cañada Flintridge, CA" };
const why = [["stethoscope","Two physicians, on-site daily","The owners are the doctors, and they care for you in person, every day."],["heart","Whole-person medical care","Our lead physician (internal and family medicine) watches your full health through withdrawal."],["home","A private, family-run home","\"Feels like home, not a clinic\" is the recurring theme in our 5.0-star reviews."],["mat","MAT to protect sobriety","Relapse-prevention medication like long-acting Vivitrol, started before discharge."],["globe","Bilingual, culturally-aware care","English, Spanish, and Korean, with a team that respects where you come from."]];
const continuum = [["detox","Medical Detox","24/7 physician-supervised withdrawal management.","/programs/medical-detox/"],["home","Residential Treatment","Live-in care after detox, in a real home.","/programs/residential-treatment/"],["dual","Dual Diagnosis","Integrated care for co-occurring anxiety, depression, or trauma.","/programs/dual-diagnosis-treatment/"],["mat","Medication-Assisted Treatment","Physician-prescribed medication to ease withdrawal and prevent relapse.","/programs/medication-assisted-treatment/"],["heart","Continuing Care","Trusted local referrals plus personal physician follow-up.","/programs/continuing-care/"]];
---
<Layout title="Medical Detox near La Cañada Flintridge | Regain Hope Detox and Recovery Center" description="Private, physician-supervised medical detox for La Cañada Flintridge residents, about 20 min away in Burbank. Doctor-owned, home-like, discreet. PPO accepted. Call 24/7." schema={[pageSchema, faqSchema]}>
  <Hero variant="form" eyebrow="For La Cañada Flintridge, CA · ~20 Min Away in Burbank · 24/7" title="Medical Detox for La Cañada Flintridge, CA Residents" byline="Mileidys Gomez Gonzalez, MD" chips={["~20 min from La Cañada","Owned & run by two physicians","Private & discreet","PPO accepted"]} />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Two physicians on-site daily</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Private medical detox near La Cañada Flintridge, California</h2>
    <p>La Cañada Flintridge is one of the most affluent and tightly-knit communities in Los Angeles County, a foothill city of roughly 20,000 at the base of the San Gabriel Mountains, home to the Jet Propulsion Laboratory, Descanso Gardens, and some of the region's top-rated schools. It's a place of accomplished families and quiet success, where privacy is prized and where the pressures that accompany high achievement, and the alcohol or prescription use that can quietly grow alongside them, are rarely discussed openly.</p>
    <p>For La Cañada residents ready for help, <b>discreet, physician-led detox is a short drive away.</b> Regain Hope Detox and Recovery Center sits about 20 minutes away in neighboring Burbank, offering 24/7 doctor-supervised detox inside a private residence rather than a clinical facility. You stay close to family and the foothills you call home while stepping just far enough from daily life to focus on recovery. For people who have spent years appearing to have it all together, a small, private, doctor-owned home nearby can be the difference between continuing to hide a problem and finally addressing it.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Why a discreet, nearby option changes the decision</h2>
    <p>In a community as small and connected as La Cañada Flintridge, the fear of being seen often outweighs the willingness to get help. People worry about a neighbor recognizing them, about questions at school or church, about an institutional setting that feels stigmatizing. So they wait, or they try to detox at home, which is both medically risky and surrounded by every trigger.</p>
    <p>A small, physician-owned home minutes away dissolves those barriers. There's no large lobby, no crowd, no signage announcing why you're there, just a private residence and the two doctors who own and run the program. You're close enough that a short stay doesn't disrupt your family, and a flexible technology policy lets professionals stay reachable. Here, discretion isn't a marketing promise; it's simply how a small family-run home operates.</p>
  </div></section>

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Why choose Regain Hope</span><h2>Why La Cañada Flintridge residents choose us</h2></div>
    <div class="grid3">
      {why.map(([ico, t, d]) => (<div class="pcard"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p></div>))}
    </div>
  </div></section>

  <ImageFeature bg="cream" image="/images/stock/wellness-lifestyle.webp" alt="A calm reset in recovery near La Cañada Flintridge" side="right" eyebrow="Close to home, a real reset" title="Far enough to heal, close enough to stay connected" body="A quiet Burbank home with a private garden and water-feature courtyard offers La Cañada residents a calm, dignified place to recover, close to home and family, away from the spotlight. Out-of-state family? We coordinate travel." points={[['pin', 'A short, familiar drive from La Cañada Flintridge'], ['heart', 'Family stays close'], ['home', 'A private, home-like setting']]} />

  <section><div class="container rich" style="max-width:820px;">
    <h2>What medical detox involves</h2>
    <p>Medical detox safely clears alcohol or drugs from your body under 24/7 medical supervision while a care team manages withdrawal. Because alcohol, benzodiazepine, and opioid withdrawal can be dangerous, and for some substances life-threatening, supervised detox is far safer than quitting alone.</p>
    <p>At Regain Hope Detox and Recovery Center, your detox is overseen <b>in person, every day</b> by the two physicians who own the program, not a remote doctor checking in by phone. The process generally runs <b>5–10 days</b> depending on the substance and your health, and flows directly into <a href="/programs/residential-treatment/">residential treatment</a> so progress doesn't stall.</p>
  </div></section>

  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">The continuum</span><h2>Detox and treatment available to La Cañada Flintridge residents</h2></div>
    <div class="grid3">
      {continuum.map(([ico, t, d, href]) => (<a class="pcard" href={href} style="text-decoration:none;display:block;"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p><span class="more">Learn more →</span></a>))}
    </div>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Addictions we treat for La Cañada Flintridge clients</h2>
    <p>We provide detox and treatment for alcohol, opioids and fentanyl, benzodiazepines, stimulants (meth and cocaine), prescription drugs, and polysubstance use, plus co-occurring anxiety, depression, and trauma through integrated <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis care</a>. See everything we treat on our <a href="/what-we-treat/">What We Treat</a> page.</p>
  </div></section>

  <section class="bg-cream"><div class="container"><div class="loc">
    <div>
      <span class="eyebrow">Directions</span>
      <h2>How to reach us from La Cañada Flintridge, CA</h2>
      <p>Regain Hope Detox and Recovery Center is at <b>1134 N Lima St, Burbank, CA 91505</b>, about <b>20 minutes</b> from La Cañada via the SR-134 west through Glendale. From the foothills or near Descanso Gardens, it's a quick, low-stress drive. We're near Hollywood Burbank Airport for out-of-town family, and we can help arrange transportation to start treatment.</p>
      <p style="margin-top:14px;"><a href="/admissions/verify-insurance/" class="btn btn-outline">Verify Your Insurance →</a></p>
    </div>
    <div class="locmap"><iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3300.9999518658433!2d-118.34512380000001!3d34.1719189!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2953e35a0fe73%3A0xfb985e3d6fdb6993!2sRegain%20hope%20detox%20and%20recovery%20center!5e0!3m2!1sen!2sco!4v1781487303442!5m2!1sen!2sco" loading="lazy" title="Driving map from La Cañada Flintridge to Regain Hope Detox and Recovery Center"></iframe></div>
  </div></div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Addiction in the La Cañada Flintridge area, you're not alone</h2>
    <p>In a small, high-achieving foothill community like La Cañada Flintridge, substance use often grows quietly behind academic and professional success, and the close-knit nature of the city can make people reluctant to be seen seeking help. Across Los Angeles County, tens of thousands of people enter substance-use treatment each year, and affluence offers no immunity. Reaching out is the turning point, and because Regain Hope sits about 20 minutes away in Burbank, La Cañada families can support a loved one discreetly through detox without long separations, with many clients continuing as outpatients close to home afterward.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Fresh air and recovery near La Cañada</h2>
    <p>Recovery at Regain Hope moves outdoors, and few areas are as connected to nature as La Cañada Flintridge, nestled against the San Gabriels. Cherry Canyon, the trails of the Angeles foothills, and the serene grounds of Descanso Gardens reflect the kind of calm, restorative environment that supports early recovery: the walks, fresh air, and stillness we build into each day. Combined with our private garden and water-feature courtyard in Burbank, clients from La Cañada recover somewhere that echoes the foothills they call home.</p>
  </div></section>

  <Reviews bg="white" />

  <InsuranceBanner />

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Detox near La Cañada Flintridge, CA, frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <section class="ctaband"><div class="container">
    <h2>Discreet help, minutes from La Cañada Flintridge</h2>
    <p>One confidential call is all it takes. Our admissions line is open 24/7.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
