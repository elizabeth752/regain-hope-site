---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import InsuranceBanner from '../../components/InsuranceBanner.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  {
    "q": "Is there a medical detox center near Pasadena?",
    "a": "Yes — about 20 minutes away in neighboring Burbank."
  },
  {
    "q": "How far is it from Pasadena?",
    "a": "About 20 minutes west via the SR-134."
  },
  {
    "q": "Why leave Pasadena for detox instead of staying home?",
    "a": "Detoxing among your usual triggers is risky and relapse-prone; a short move to a supervised, home-like setting improves safety and focus."
  },
  {
    "q": "Is treatment private and discreet?",
    "a": "Yes — a small, family-run residence, not an institutional facility."
  },
  {
    "q": "Can I stay reachable for work?",
    "a": "Yes — a flexible technology policy supports working professionals."
  },
  {
    "q": "Can my family in Pasadena stay involved?",
    "a": "Yes — the close location keeps family connected, and family therapy is available on request."
  },
  {
    "q": "Does it accept PPO insurance?",
    "a": "Most PPO plans, as an out-of-network provider; benefits verified free."
  },
  {
    "q": "What substances can be detoxed from?",
    "a": "Alcohol, opioids and fentanyl, benzodiazepines, stimulants, prescription drugs, and polysubstance use."
  },
  {
    "q": "Is detox done with 24/7 medical supervision?",
    "a": "Yes — two physicians provide in-person care daily, with around-the-clock monitoring."
  },
  {
    "q": "Is care available in Spanish or Korean?",
    "a": "Yes — care is provided in English, Spanish, and Korean."
  }
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalClinic', name: 'Regain Hope Detox and Recovery Center', address: { '@type': 'PostalAddress', streetAddress: '1134 N Lima St', addressLocality: 'Burbank', addressRegion: 'CA', postalCode: '91505', addressCountry: 'US' }, telephone: '+1-818-281-2458', geo: { '@type': 'GeoCoordinates', latitude: 34.1719189, longitude: -118.3451238 }, areaServed: 'Pasadena, CA', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };
const why = [["stethoscope","Two physicians, on-site daily","The owners are the doctors — and they care for you in person, every day."],["heart","Whole-person medical care","Our lead physician (internal and family medicine) watches your full health through withdrawal."],["home","A private, family-run home","\"Feels like home, not a clinic\" is the recurring theme in our 5.0-star reviews."],["mat","MAT to protect sobriety","Relapse-prevention medication like long-acting Vivitrol, started before discharge."],["globe","Bilingual, culturally-aware care","English, Spanish, and Korean, with a team that respects where you come from."]];
const continuum = [["detox","Medical Detox","24/7 physician-supervised withdrawal management.","/programs/medical-detox/"],["home","Residential Treatment","Live-in care after detox, in a real home.","/programs/residential-treatment/"],["dual","Dual Diagnosis","Integrated care for co-occurring anxiety, depression, or trauma.","/programs/dual-diagnosis-treatment/"],["mat","Medication-Assisted Treatment","Physician-prescribed medication to ease withdrawal and prevent relapse.","/programs/medication-assisted-treatment/"],["heart","Continuing Care","Trusted local referrals plus personal physician follow-up.","/programs/continuing-care/"]];
---
<Layout title="Medical Detox near Pasadena, CA | Regain Hope Detox and Recovery Center" description="Physician-supervised medical detox for Pasadena, CA residents — about 20 minutes away in Burbank. Two doctors on-site daily, MAT, private home setting. PPO accepted. Call 24/7." schema={[pageSchema, faqSchema]}>
  <Hero variant="form" eyebrow="For Pasadena, CA · ~20 Min Away in Burbank · 24/7" title="Medical Detox for Pasadena, CA Residents" byline="Mileidys Gomez Gonzalez, MD" chips={["~20 min from Pasadena via SR-134","Owned & run by two physicians","Flexible technology policy","PPO accepted"]} />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Two physicians on-site daily</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Trusted medical detox near Pasadena, California</h2>
    <p>Pasadena — the Crown City — is one of the most distinctive communities in Los Angeles County: home to Caltech and the Jet Propulsion Laboratory, the Rose Bowl and the Tournament of Roses, the galleries and restaurants of Old Town, and historic neighborhoods of Craftsman homes. It's a city of roughly 138,000 with deep professional and academic roots, and like every affluent community it carries a quieter story of high-functioning alcohol use, prescription-drug dependence, and stress that builds behind closed doors.</p>
    <p>For Pasadena residents ready to take the first step, <b>physician-led medical detox is a short drive away.</b> Regain Hope Detox and Recovery Center is located in neighboring Burbank — about 20 minutes west of Pasadena on the SR-134 — offering 24/7 doctor-supervised detox in a private, home-like setting instead of a clinical ward. You stay close to family and your responsibilities while stepping just far enough from the routines and pressures tied to using. For accomplished people who've spent years holding everything together, that mix of nearby and discreet is often what finally makes asking for help feel safe.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Why leaving Pasadena — just for a little while — helps</h2>
    <p>The toughest place to detox is the one where addiction grew: the same study, the same social circles, the same standing reservations and pressures of a high-achieving life. Trying to white-knuckle it at home, surrounded by all of it, is how the first hard days fall apart. Yet leaving the area entirely can feel out of the question when you have family, a career, and a reputation to protect in a community as tight-knit as Pasadena.</p>
    <p>Burbank offers the middle path. It's close enough for family to stay involved and for a smooth handoff to local outpatient care later, but far enough to break the daily pattern during the most vulnerable phase of withdrawal. And because Regain Hope is small, private, and physician-owned, the discretion Pasadena residents value is part of the design.</p>
  </div></section>

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Why choose Regain Hope</span><h2>Why Pasadena residents choose us</h2></div>
    <div class="grid3">
      {why.map(([ico, t, d]) => (<div class="pcard"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p></div>))}
    </div>
  </div></section>

  <ImageFeature bg="cream" image="/images/stock/holistic-care.webp" alt="A calm reset in recovery near Pasadena" side="right" eyebrow="Close to home, a real reset" title="Far enough to heal, close enough to stay connected" body="A quiet Burbank home with a private garden and water-feature courtyard, about 20 minutes over the 134 from Pasadena — so family stays close while you focus on getting well. Out-of-state family? We coordinate travel." points={[['pin', 'A short, familiar drive from Pasadena'], ['heart', 'Family stays close'], ['home', 'A private, home-like setting']]} />

  <section><div class="container rich" style="max-width:820px;">
    <h2>What medical detox involves</h2>
    <p>Medical detox safely clears alcohol or drugs from your body under 24/7 medical supervision while a care team manages withdrawal. Because alcohol, benzodiazepine, and opioid withdrawal can be dangerous — and for some substances life-threatening — supervised detox is far safer than quitting alone.</p>
    <p>At Regain Hope Detox and Recovery Center, your detox is overseen <b>in person, every day</b> by the two physicians who own the program — not a remote doctor checking in by phone. The process generally runs <b>5–10 days</b> depending on the substance and your health, and flows directly into <a href="/programs/residential-treatment/">residential treatment</a> so progress doesn't stall.</p>
  </div></section>

  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">The continuum</span><h2>Detox and treatment available to Pasadena residents</h2></div>
    <div class="grid3">
      {continuum.map(([ico, t, d, href]) => (<a class="pcard" href={href} style="text-decoration:none;display:block;"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p><span class="more">Learn more →</span></a>))}
    </div>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Addictions we treat for Pasadena clients</h2>
    <p>We provide detox and treatment for alcohol, opioids and fentanyl, benzodiazepines, stimulants (meth and cocaine), prescription drugs, and polysubstance use — plus co-occurring anxiety, depression, and trauma through integrated <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis care</a>. See everything we treat on our <a href="/what-we-treat/">What We Treat</a> page.</p>
  </div></section>

  <section class="bg-cream"><div class="container"><div class="loc">
    <div>
      <span class="eyebrow">Directions</span>
      <h2>How to reach us from Pasadena, CA</h2>
      <p>Regain Hope Detox and Recovery Center is at <b>1134 N Lima St, Burbank, CA 91505</b> — about <b>20 minutes from Pasadena</b>, a straight shot west on the SR-134 through Glendale. From Old Town or the Caltech area, the drive is quick and low-stress, and you're at our door before a typical cross-town commute would clear the interchange. We're near Hollywood Burbank Airport for out-of-town family, and we can help arrange transportation to start treatment.</p>
      <p style="margin-top:14px;"><a href="/admissions/verify-insurance/" class="btn btn-outline">Verify Your Insurance →</a></p>
    </div>
    <div class="locmap"><iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3300.9999518658433!2d-118.34512380000001!3d34.1719189!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2953e35a0fe73%3A0xfb985e3d6fdb6993!2sRegain%20hope%20detox%20and%20recovery%20center!5e0!3m2!1sen!2sco!4v1781487303442!5m2!1sen!2sco" loading="lazy" title="Driving map from Pasadena to Regain Hope Detox and Recovery Center"></iframe></div>
  </div></div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Addiction in the Pasadena area — you're not alone</h2>
    <p>In a community as accomplished as Pasadena — academics, professionals, multigenerational families — substance use often grows quietly behind a capable exterior, masked by high-functioning routines. Across Los Angeles County, tens of thousands of people enter substance-use treatment each year, and the San Gabriel Valley is no exception. Asking for help isn't a failure of willpower; it's the turning point. Because Regain Hope is about 20 minutes west in Burbank, Pasadena families can stay involved through detox without uprooting their lives — and many clients continue with our physicians as outpatients after they step down, keeping care close to home.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Fresh air and recovery near Pasadena</h2>
    <p>Recovery at Regain Hope moves outdoors, and the Pasadena area is rich with the kind of nature that supports it. Eaton Canyon and its waterfall, the Arroyo Seco below the Rose Bowl, and the foothill trails of the San Gabriels are the sort of restorative settings that inspire the walks, fresh air, and movement we weave into early recovery. Combined with our private garden and courtyard in Burbank, clients from Pasadena recover in a calm environment that echoes the foothills they know.</p>
  </div></section>

  <Reviews bg="white" />

  <InsuranceBanner />

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Detox near Pasadena, CA — frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <section class="ctaband"><div class="container">
    <h2>Help is a short drive from Pasadena</h2>
    <p>One confidential call is all it takes. Our admissions line is open 24/7.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
