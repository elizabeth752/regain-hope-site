---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import ImageFeature from '../../components/ImageFeature.astro';
import InsuranceBanner from '../../components/InsuranceBanner.astro';
import Reviews from '../../components/Reviews.astro';

const faqs = [
  { q: 'Is there a medical detox center near Glendale, CA?', a: 'Yes — physician-supervised medical detox minutes from Glendale in neighboring Burbank.' },
  { q: 'How far is the facility from Glendale?', a: 'About 15 minutes from downtown Glendale via the SR-134.' },
  { q: 'Why should I leave Glendale for detox instead of staying home?', a: 'Detoxing among your usual triggers is risky and relapse-prone; a short move to a supervised, home-like setting greatly improves safety and focus while keeping family close.' },
  { q: 'Can my family in Glendale stay involved during treatment?', a: 'Yes — the close location keeps family connected, and family therapy is available on request.' },
  { q: 'Do you offer care in Spanish or Korean?', a: 'Yes — care is provided in English, Spanish, and Korean. Ask our team about language support for Glendale\'s Armenian-speaking community.' },
  { q: 'Does detox near Glendale accept PPO insurance?', a: 'Most PPO plans, as an out-of-network provider; benefits are verified for free.' },
  { q: 'What substances can be detoxed from?', a: 'Alcohol, opioids and fentanyl, benzodiazepines, stimulants, prescription drugs, and polysubstance use.' },
  { q: 'Is detox done with 24/7 medical supervision?', a: 'Yes — two physicians provide in-person care daily, with around-the-clock monitoring.' },
  { q: 'How long does detox take?', a: 'Typically 5–10 days depending on the substance and your health.' },
  { q: 'What happens after detox?', a: 'You step into residential treatment, then a continuing-care plan with trusted local referrals — many Glendale-area clients keep seeing our physicians as outpatients.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const pageSchema = { '@context': 'https://schema.org', '@type': 'MedicalClinic', name: 'Regain Hope Detox and Recovery Center', address: { '@type': 'PostalAddress', streetAddress: '1134 N Lima St', addressLocality: 'Burbank', addressRegion: 'CA', postalCode: '91505', addressCountry: 'US' }, telephone: '+1-818-281-2458', geo: { '@type': 'GeoCoordinates', latitude: 34.1719189, longitude: -118.3451238 }, areaServed: 'Glendale, CA', reviewedBy: { '@type': 'Person', name: 'Mileidys Gomez Gonzalez, MD' } };

const why = [
  ['stethoscope', 'Two physicians, on-site daily', 'The owners are the doctors — and they care for you in person, every day.'],
  ['heart', 'Whole-person medical care', 'Our lead physician (internal & family medicine) watches your full health through withdrawal.'],
  ['home', 'A family-run home, minutes from Glendale', '"Feels like home, not a clinic" is the recurring theme in our 5.0-star reviews.'],
  ['mat', 'MAT to protect sobriety', 'Relapse-prevention medication like long-acting Vivitrol, started before discharge.'],
  ['globe', 'Bilingual, culturally-aware care', 'English, Spanish, and Korean, with a team that respects where you come from.'],
];
const continuum = [
  ['detox', 'Medical Detox', '24/7 physician-supervised withdrawal management.', '/programs/medical-detox/'],
  ['home', 'Residential Treatment', 'Live-in care after detox, in a real home.', '/programs/residential-treatment/'],
  ['dual', 'Dual Diagnosis', 'Integrated care for co-occurring anxiety, depression, or trauma.', '/programs/dual-diagnosis-treatment/'],
  ['mat', 'Medication-Assisted Treatment', 'Physician-prescribed medication to ease withdrawal and prevent relapse.', '/programs/medication-assisted-treatment/'],
  ['heart', 'Continuing Care', 'Trusted local referrals plus personal physician follow-up.', '/programs/continuing-care/'],
];
---
<Layout
  title="Medical Detox in Glendale, CA | Regain Hope Detox and Recovery Center"
  description="Physician-supervised medical detox for Glendale, CA residents — minutes away in Burbank. Two doctors on-site daily, MAT, bilingual care, private home setting. PPO accepted. Call 24/7."
  schema={[pageSchema, faqSchema]}
>
  <Hero
    variant="form"
    eyebrow="For Glendale, CA · Minutes Away in Burbank · 24/7"
    title="Medical Detox for Glendale, CA Residents"
    byline="Mileidys Gomez Gonzalez, MD"
    chips={['~15 min from Glendale via SR-134', 'Owned & run by two physicians', 'Bilingual care (EN · ES · 한국어)', 'PPO accepted']}
  />

  <div class="trust"><div class="container">
    <span><span class="star">★</span> 5.0 on Google</span><span class="sep">|</span><span>Joint Commission Accredited</span><span class="sep">|</span><span>California DHCS Licensed</span><span class="sep">|</span><span>LegitScript Certified</span><span class="sep">|</span><span>Two physicians on-site daily</span>
  </div></div>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Trusted medical detox near Glendale, California</h2>
    <p>Glendale is the third-largest city in Los Angeles County — a community of roughly 196,000 people known for its strong family ties, a large and vibrant Armenian-American population, and neighborhoods that range from the shops of the Americana at Brand to the quiet streets below the Verdugo Mountains. It's also a community that, like every part of Los Angeles, has felt the weight of the alcohol, fentanyl, and prescription-drug crisis.</p>
    <p>For Glendale residents ready to take the first step, <b>medically supervised detox is just minutes away.</b> Regain Hope Detox and Recovery Center is located in neighboring Burbank — about 15 minutes from downtown Glendale via the SR-134 — and offers 24/7 physician-supervised detox in a private, home-like setting. You stay close to family, work, and the life you're rebuilding, while stepping just far enough away from the people, places, and routines tied to using. For many people, that combination — close to home but a genuine change of scene — is exactly what makes early recovery possible.</p>
  </div></section>

  <section class="bg-cream"><div class="container rich" style="max-width:820px;">
    <h2>Why a short trip to Burbank can change everything</h2>
    <p>Recovery is hardest in the same environment where addiction took hold — the same block, the same friends, the same liquor store or dealer, the same stress. Detoxing at home, surrounded by all of it, is how good intentions unravel in the first 72 hours. At the same time, traveling far from family for treatment can feel isolating and overwhelming, especially when you're already frightened.</p>
    <p>Burbank threads that needle for Glendale residents. It's close enough that loved ones can visit, that you're never far from home, and that the handoff to local outpatient care later is seamless — but far enough that you're not detoxing in the middle of your triggers. And because Glendale is one of the most culturally diverse cities in California, it matters that our care is delivered in <b>English, Spanish, and Korean</b>, with a small, family-run team that treats you as a person, not a case number.</p>
  </div></section>

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">Why choose Regain Hope</span><h2>Why Glendale residents choose us</h2></div>
    <div class="grid3">
      {why.map(([ico, t, d]) => (
        <div class="pcard"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p></div>
      ))}
    </div>
  </div></section>

  <ImageFeature
    bg="cream"
    image="/images/stock/holistic-care.webp"
    alt="A person finding a calm reset in recovery near Glendale"
    side="right"
    eyebrow="Close to home, a real reset"
    title="A genuine change of scene — without leaving the people who matter"
    body="A quiet Burbank neighborhood with a private garden and water-feature courtyard, minutes from Glendale across the 134 — so family stays involved while you focus on getting well. Out-of-state family? We help arrange travel."
    points={[['pin', '~15 minutes from downtown Glendale'], ['heart', 'Family stays close'], ['home', 'A private, home-like setting']]}
  />

  <section><div class="container rich" style="max-width:820px;">
    <h2>What medical detox involves</h2>
    <p>Medical detox is the process of safely clearing alcohol or drugs from your body under 24/7 medical supervision while a care team manages withdrawal. Withdrawal from alcohol, benzodiazepines, and opioids can be dangerous — and for some substances, life-threatening — which is why detoxing alone is so risky. With physicians on-site, medications ease the worst of it, and you're monitored around the clock.</p>
    <p>At Regain Hope Detox and Recovery Center, your detox is overseen <b>in person, every day</b> by the two physicians who own the program — not a remote doctor checking in by phone. The process generally runs <b>5–10 days</b> depending on the substance and your health, and flows directly into <a href="/programs/residential-treatment/">residential treatment</a> so progress doesn't stall.</p>
  </div></section>

  <section class="bg-cream"><div class="container">
    <div class="sec-head"><span class="eyebrow">The continuum</span><h2>Detox and treatment available to Glendale residents</h2></div>
    <div class="grid3">
      {continuum.map(([ico, t, d, href]) => (
        <a class="pcard" href={href} style="text-decoration:none;display:block;"><div class="ico"><Icon name={ico} /></div><h3>{t}</h3><p>{d}</p><span class="more">Learn more →</span></a>
      ))}
    </div>
  </div></section>

  <section><div class="container rich" style="max-width:820px;">
    <h2>Addictions we treat for Glendale clients</h2>
    <p>We provide detox and treatment for alcohol, opioids and fentanyl, benzodiazepines, stimulants (meth and cocaine), prescription drugs, and polysubstance use — plus co-occurring anxiety, depression, and trauma through integrated <a href="/programs/dual-diagnosis-treatment/">dual-diagnosis care</a>. See everything we treat on our <a href="/what-we-treat/">What We Treat</a> page.</p>
  </div></section>

  <section class="bg-cream"><div class="container"><div class="loc">
    <div>
      <span class="eyebrow">Directions</span>
      <h2>How to reach us from Glendale</h2>
      <p>Regain Hope Detox and Recovery Center is at <b>1134 N Lima St, Burbank, CA 91505</b> — about <b>15 minutes from downtown Glendale</b>, a straight, low-stress drive west on the SR-134. From the Americana at Brand or Brand Boulevard, you're at our door before a Glendale-to-DTLA commute would even clear the interchange. We're near Hollywood Burbank Airport, which makes arrivals easy for out-of-town family. Need a ride to start treatment? Ask about transportation assistance.</p>
      <p>Coming from north Glendale or Montrose? The 2 down to the 134 brings you in from the other direction in about the same time. Whether you're near Glendale Community College, Adventist Health Glendale, or the Glendale Galleria, you're only a short, familiar drive from physician-led detox — close enough to come back for outpatient follow-up once you've stepped down from residential care.</p>
      <p style="margin-top:14px;"><a href="/admissions/verify-insurance/" class="btn btn-outline">Verify Your Insurance →</a></p>
    </div>
    <div class="locmap"><iframe src="https://www.google.com/maps?q=1134%20N%20Lima%20St%2C%20Burbank%2C%20CA%2091505&output=embed" loading="lazy" title="Driving map from Glendale to Regain Hope Detox and Recovery Center"></iframe></div>
  </div></div></section>

  <Reviews bg="white" />

  <InsuranceBanner />

  <section><div class="container">
    <div class="sec-head"><span class="eyebrow">FAQ</span><h2>Detox near Glendale, CA — frequently asked questions</h2></div>
    <div class="faqwrap">{faqs.map((f, i) => (<details open={i === 0}><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div></section>

  <section class="ctaband"><div class="container">
    <h2>Help is minutes from Glendale</h2>
    <p>One confidential call is all it takes. Our admissions line is open 24/7.</p>
    <div class="hero-cta" style="justify-content:center;"><a href="/admissions/verify-insurance/" class="btn btn-gold">Verify Your Insurance</a></div>
  </div></section>
</Layout>
